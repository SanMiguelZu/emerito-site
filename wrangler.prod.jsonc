// Production deployment config — used by GitHub Actions (wrangler deploy --config wrangler.prod.jsonc).
// Do NOT use for local dev; wrangler.jsonc handles that.
{
  "name": "emerito-site",
  "compatibility_date": "2026-04-22",
  "main": "dist/server/entry.mjs",
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  // Contact form now runs through Formspree client-side; no server env vars needed.
  "vars": {},
  "observability": {
    "enabled": true
  }
}
