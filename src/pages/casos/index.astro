---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Casos de estudio"
  description="Comunicación basada en ciencia del comportamiento, validada en campo. Casos completos: problema, diagnóstico, intervención, resultado."
  lang="es"
  alternateHref="/en/case-studies"
>

  <!-- ─── 1. HERO ─────────────────────────────────────────────────── -->
  <section class="bg-sand py-24 lg:py-28">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <p class="text-[10px] font-semibold tracking-[0.15em] uppercase text-accent mb-6">Casos</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-ocean leading-[1.05] mb-6">
        Casos de estudio
      </h1>
      <p class="text-lg text-ink/60 leading-relaxed max-w-2xl">
        Comunicación basada en ciencia del comportamiento, validada en campo.
        Casos completos: problema, diagnóstico, intervención, resultado.
      </p>
    </div>
  </section>

  <!-- ─── 2. FEATURED CASE ─────────────────────────────────────────── -->
  <section class="bg-white border-y border-ink/6 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

        <!-- PLACEHOLDER: airfan_candles.jpg — still principal del caso Airfan -->
        <figure class="bg-ink/8 rounded-sm aspect-[4/3] flex items-center justify-center">
          <figcaption class="text-[10px] text-ink/25 font-mono text-center px-4">
            [IMAGEN: airfan_candles.jpg<br/>Fila de velas — still del storyboard · 1200 × 900 px]
          </figcaption>
        </figure>

        <div>
          <p class="text-[10px] font-bold tracking-widest uppercase text-accent mb-4">
            Trabajo seguro en alturas
          </p>
          <h2 class="text-3xl font-extrabold text-ocean leading-tight mb-4">
            Veterano, no temerario
          </h2>
          <p class="text-ink/65 leading-relaxed mb-3">
            ¿Cómo logramos que técnicos veteranos sigan los protocolos de seguridad
            cuando la cultura de cuadrilla penaliza la obediencia?
          </p>
          <p class="text-xs text-ink/35 mb-8">
            Cliente: Airfan · Mantenimiento industrial de HVAC · 2025
          </p>
          <a
            href="/casos/trabajo-seguro-en-alturas"
            class="inline-block bg-ocean text-sand text-sm font-semibold px-6 py-3 rounded-sm hover:bg-ocean/85 transition-colors"
          >
            Leer caso completo →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── 3. FUTURE CASES PLACEHOLDER ─────────────────────────────── -->
  <section class="bg-sand py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center">
      <p class="text-ink/45 text-sm mb-6">Más casos en producción.</p>
      <p class="text-ink/65 mb-8">¿Querés ser el siguiente?</p>
      <a
        href="/contacto"
        class="text-sm font-semibold text-ocean hover:text-accent transition-colors"
      >
        Hablemos →
      </a>
    </div>
  </section>

</BaseLayout>
