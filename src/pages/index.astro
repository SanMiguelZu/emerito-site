---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Inicio" lang="es">
  <section class="px-6 py-24 max-w-4xl mx-auto">
    <p class="text-sm font-semibold text-current uppercase tracking-widest mb-4">Inicio — Paso 3</p>
    <h1 class="text-4xl font-bold text-ocean mb-6">
      Hacemos comunicación que cambia comportamientos.
    </h1>
    <p class="text-lg text-ink/70">
      Diseñamos diagnósticos y videos para empresas donde la seguridad, la formación o el cambio cultural no pueden fallar.
    </p>
  </section>
</BaseLayout>
