---
import BaseLayout from '../layouts/BaseLayout.astro';

// ── What we make: the four main projects, each pointing to its page. ──
const products = [
  {
    label: 'Training series',
    title: 'Zero Risk Zone',
    desc: 'A character-driven series for crews that sleep through safety training.',
    href: '/work/zero-risk-zone/',
    media: { type: 'img', src: '/images/Proyecto 1-Trabajo_Seguro_En_Alturas-AI/Zero Risk Zone_Banner.webp', alt: 'Zero Risk Zone safety training series banner' },
  },
  {
    label: 'Games & experiences',
    title: 'Palmódromo Medellín',
    desc: 'Urban narrative racing through the streets of Medellín.',
    href: '/work/palmodromo-medellin/',
    media: { type: 'video', src: '/images/Palmodromo/DriftRender.mp4' },
  },
  {
    label: 'Experiments',
    title: 'The Lab',
    desc: 'Quick content creation experiments in 3D, AI, and code.',
    href: '/lab/',
    media: { type: 'video', src: '/images/LAB/CatWalk_V020001-0109.mp4' },
  },
  {
    label: 'Collectibles · Team credit',
    title: 'Bacano Go!',
    desc: 'The Carnaval de Barranquilla as digital collectibles.',
    href: '/work/bacano-go/',
    media: { type: 'img', src: '/images/Bacano Go/Carnaval_Banner_HomePage.webp', alt: 'Bacano Go! carnival characters' },
  },
] as const;

// ── The method: three disciplines, one channel. ──
const pillars = [
  {
    no: '01',
    name: 'Future Thinking',
    sub: 'We read the terrain',
    desc: 'We understand where the organization is heading and what behaviors will matter in three years.',
    color: 'var(--color-ocean)',
  },
  {
    no: '02',
    name: 'Behavioral Science',
    sub: 'We map the current',
    desc: 'We diagnose the real problem with COM-B: capabilities, opportunities, and motivations.',
    color: 'var(--color-orange)',
  },
  {
    no: '03',
    name: 'Creative Content',
    sub: 'We trace the channel',
    desc: 'We build the intervention: the character, the story, the film that changes how people act.',
    color: 'var(--color-ocean)',
  },
] as const;

// ── What clients come for: needs first, keywords doing the SEO work. ──
const needs = [
  ['01', 'Training videos', 'Safety and compliance content your teams actually watch, remember, and act on.'],
  ['02', 'Brand characters & mascots', 'Original character design with full IP: a face your audience recognizes anywhere.'],
  ['03', '3D animation', 'Character animation, product renders, and simulations with real craft behind them.'],
  ['04', 'AI-assisted production', 'Modern pipelines that keep quality high and budgets realistic.'],
  ['05', 'Social content systems', 'Characters, templates, and stickers your team can actually keep up with.'],
  ['06', 'Games & interactive', 'Narrative games and experiences people step into, not scroll past.'],
  ['07', 'Video production', 'Script to screen: shooting, editing, and post.'],
  ['08', 'Content strategy', 'What to make, for whom, and why it will stick.'],
] as const;
---

<BaseLayout
  title="Creative Content Studio"
  description="Emerito is a creative content studio in Medellín. Original brand characters, animated series, games, experiences, and training content that behaves like entertainment."
  lang="en"
  alternateHref="/es/"
>
  <div class="pop-root relative w-full overflow-hidden">

    <!-- ══ HERO ══ -->
    <section class="relative bg-cream overflow-hidden border-b-[3px] border-blue-black">
      <div class="max-w-[1320px] mx-auto px-6 lg:px-[46px] grid lg:grid-cols-[1.04fr_0.96fr] gap-8 items-stretch lg:min-h-[640px] lg:h-[calc(100vh-66px)]">
        <!-- left message -->
        <div class="py-16 lg:py-0 flex flex-col justify-center relative z-[3]">
          <p class="inline-flex items-center gap-2.5 font-sans font-extrabold text-[12.5px] tracking-[0.09em] uppercase text-blue-black mb-6">
            <span class="inline-block bg-orange border-2 border-blue-black rounded-full px-3 py-1">Medellín, CO</span>
            Creative content studio
          </p>
          <h1 class="font-display font-medium text-[clamp(44px,5.8vw,88px)] leading-[0.9] tracking-[-0.03em] text-blue-black mb-6">
            Give your message a <em class="italic text-orange">character</em> people remember.
          </h1>
          <p class="text-lg leading-[1.55] text-blue-black/75 mb-8 max-w-[470px]">
            Emerito is a creative content studio in Medellín. Brand characters, animated
            series, games, and training content people actually <strong>watch, remember, and act on.</strong>
          </p>
          <div class="flex gap-3.5 flex-wrap">
            <a
              href="/work/"
              data-cursor="cta"
              class="pop-btn pop-border pop-shadow-sm inline-flex items-center gap-2.5 bg-orange text-blue-black text-[15px] font-extrabold px-7 py-4 rounded-full"
            >
              Explore the work →
            </a>
            <a
              href="/#contacto"
              data-cursor="link"
              class="pop-btn pop-border pop-shadow-sm bg-cream text-blue-black text-[15px] font-extrabold px-6 py-4 rounded-full"
            >
              Let's talk
            </a>
          </div>
        </div>
        <!-- right: character standing on blue block, facing the message -->
        <div class="relative flex items-end justify-center overflow-hidden min-h-[380px] lg:min-h-0">
          <div class="absolute left-1/2 bottom-0 -translate-x-1/2 w-[min(100%,520px)] h-[82%] bg-ocean border-[3px] border-b-0 border-blue-black rounded-t-[44px] overflow-hidden">
            <div
              class="absolute inset-0 opacity-35"
              style="background-image: radial-gradient(#FFF6E4 1.3px, transparent 1.3px); background-size: 26px 26px;"
            ></div>
          </div>
          <span
            class="pop-hide-sm absolute top-[14%] right-[6%] font-display italic font-semibold text-[28px] text-cream bg-orange border-[2.5px] border-blue-black rounded-full px-4 py-1 rotate-[7deg] z-[3]"
            data-parallax="-0.1"
          >
            hi!
          </span>
          <img
            id="pop-rana"
            src="/images/Personajes/YellowFrog/RanaNoBg_Flipped.webp"
            alt="Emerito's yellow frog character"
            class="relative z-[2] h-[min(90%,780px)] self-end animate-[pop-float_6.5s_ease-in-out_infinite]"
            style="filter: drop-shadow(0 22px 26px rgba(6,34,47,.3));"
          />
        </div>
      </div>
    </section>

    <!-- ══ MARQUEE ══ -->
    <div class="bg-blue-black overflow-hidden py-4 border-b-[3px] border-blue-black">
      <div class="flex w-max animate-[pop-marquee_26s_linear_infinite]">
        {[0, 1].map((i) => (
          <span class="flex items-center font-mono font-semibold text-lg tracking-[0.14em] text-cream" aria-hidden={i === 1 ? 'true' : undefined}>
            <span class="px-6">CREATIVE LAB</span><span class="text-orange">✦</span>
            <span class="px-6">STORYTELLING</span><span class="text-orange">✦</span>
            <span class="px-6">AI FOR CONTENT CREATION</span><span class="text-orange">✦</span>
            <span class="px-6">DESIGNING WORLDS TO TELL STORIES</span><span class="text-orange">✦</span>
          </span>
        ))}
      </div>
    </div>

    <!-- ══ MAIN PROJECTS ══ -->
    <section id="worlds" class="bg-cream py-[90px] px-6 lg:px-[46px]">
      <div class="max-w-7xl mx-auto">
        <div class="reveal flex items-baseline gap-6 flex-wrap mb-11">
          <h2 class="font-display font-black text-[clamp(52px,7vw,110px)] leading-[0.86] tracking-[-0.03em] text-blue-black">
            Worlds we've <em class="italic text-orange">built.</em>
          </h2>
          <span class="pop-badge-sans pop-border text-xs bg-ocean text-cream px-4 py-[7px] -rotate-3">Real, shipped work ✦</span>
        </div>
        <div class="reveal grid sm:grid-cols-2 gap-6">
          {products.map((p) => (
            <a
              href={p.href}
              data-cursor="cta"
              class="pop-card pop-tile pop-border pop-shadow-md block rounded-[22px] overflow-hidden bg-cream"
            >
              <div class="overflow-hidden bg-ocean relative aspect-[16/10]">
                {p.media.type === 'video' ? (
                  <video src={p.media.src} autoplay muted loop playsinline class="w-full h-full object-cover"></video>
                ) : (
                  <img src={p.media.src} alt={'alt' in p.media ? p.media.alt : ''} class="w-full h-full object-cover" />
                )}
                <span class="pop-badge-sans absolute top-3.5 left-3.5 text-[10px] px-2.5 py-1 bg-orange text-blue-black -rotate-3">{p.label}</span>
              </div>
              <div class="p-[16px_20px_18px]">
                <p class="font-display italic font-bold text-[27px] leading-[1.05] text-blue-black mb-1">{p.title}</p>
                <p class="text-[13.5px] leading-[1.5] text-blue-black/58">{p.desc} →</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ══ THREE DISCIPLINES ══ -->
    <section id="metodo" class="bg-orange py-[90px] px-6 lg:px-[46px] border-y-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto">
        <h2 class="reveal text-center font-display font-black text-[clamp(32px,4.4vw,56px)] leading-[0.98] text-blue-black mb-2">
          There's a <em class="italic">science</em> to content people remember.
        </h2>
        <p class="reveal text-center text-base text-blue-black/72 mb-11">
          How we turn a problem into real change.
        </p>
        <div class="reveal-stagger grid md:grid-cols-3 gap-5">
          {pillars.map((p) => (
            <div class="pop-card pop-border pop-shadow-md bg-cream rounded-[24px] p-[30px_26px_28px]">
              <p
                class="font-display italic font-bold text-[56px] leading-[0.8] mb-[18px]"
                style={`color:${p.color}; -webkit-text-stroke: 2px #06222F;`}
              >
                {p.no}
              </p>
              <h3 class="font-display font-medium text-[23px] text-blue-black mb-1">{p.name}</h3>
              <p class="font-display italic text-sm text-ocean mb-3.5">{p.sub}</p>
              <p class="text-[14.5px] leading-[1.58] text-blue-black/74">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══ BEHIND THE CRAFT ══ -->
    <section id="craft" class="bg-blue-black py-[90px] px-6 lg:px-[46px] border-y-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto">
        <div class="reveal grid lg:grid-cols-[1.3fr_1fr] gap-9 items-end mb-11">
          <h2 class="font-display font-black text-[clamp(34px,4.6vw,60px)] leading-[0.96] text-cream">
            Behind <em class="italic text-orange">the craft.</em>
          </h2>
          <p class="text-[15px] leading-[1.58] text-cream/72">
            How the work gets made: character pipelines, storyboards, simulations,
            and the workflows we're testing.
          </p>
        </div>
        <div class="reveal grid grid-cols-1 lg:grid-cols-[1fr_1.1fr] gap-6 items-stretch">
          <!-- Left: big square — turntable video, stretches to full column height -->
          <a href="/craft/3d-character-process/" class="pop-card pop-tile pop-border pop-shadow-md flex flex-col rounded-[22px] overflow-hidden bg-skill-blue">
            <div class="flex-1 min-h-[340px] overflow-hidden bg-ocean relative">
              <video src="/images/Personajes/YellowFrog/turntable.mp4" autoplay muted loop playsinline class="w-full h-full object-cover"></video>
              <span class="pop-badge-sans absolute top-3.5 left-3.5 text-[10px] px-2.5 py-1 bg-orange text-blue-black">Character process</span>
            </div>
            <div class="p-[16px_20px_18px]">
              <p class="font-display italic font-bold text-[24px] leading-[1.05] text-cream mb-1">How a 3D character comes to life.</p>
              <p class="text-[13.5px] leading-[1.5] text-cream/58">From first sketch to walk cycle: the full 3D character process, documented. →</p>
            </div>
          </a>
          <!-- Right: two wide boxes stacked, bottom edges match the left square -->
          <div class="flex flex-col gap-6 h-full">
            <a href="/lab/" class="pop-card pop-tile pop-border pop-shadow-md flex flex-col rounded-[22px] overflow-hidden bg-skill-blue">
              <div class="aspect-[5/2] overflow-hidden bg-ocean relative">
                <img src="/images/Proyecto 1-Trabajo_Seguro_En_Alturas-AI/Sketch_Storyboard.webp" alt="Storyboard sketches" class="w-full h-full object-cover" loading="lazy" />
                <span class="pop-badge-sans absolute top-3.5 left-3.5 text-[10px] px-2.5 py-1 bg-orange text-blue-black">The lab</span>
              </div>
              <div class="p-[16px_20px_18px]">
                <p class="font-display italic font-bold text-[24px] leading-[1.05] text-cream mb-1">Notes on the craft</p>
                <p class="text-[13.5px] leading-[1.5] text-cream/58">Storyboards, simulation, AI workflows, and what we learn making things. →</p>
              </div>
            </a>
            <a href="/insights/medellins-animation-industry-in-transition/" class="pop-card pop-tile pop-border pop-shadow-md flex flex-col rounded-[22px] overflow-hidden bg-skill-blue">
              <div class="aspect-[5/2] overflow-hidden bg-ocean relative">
                <img src="/images/Blogs/Animation Industry in Transition.webp" alt="Medellín's animation industry in transition" class="w-full h-full object-cover" loading="lazy" />
                <span class="pop-badge-sans absolute top-3.5 left-3.5 text-[10px] px-2.5 py-1 bg-orange text-blue-black">From the blog</span>
              </div>
              <div class="p-[16px_20px_18px]">
                <p class="font-display italic font-bold text-[24px] leading-[1.05] text-cream mb-1">Medellín's animation industry in transition</p>
                <p class="text-[13.5px] leading-[1.5] text-cream/58">What AI is reshaping at the studio level — and what we're losing along the way. →</p>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ WHAT YOU NEED ══ -->
    <section id="lab" class="bg-cream py-[90px] px-6 lg:px-[46px]">
      <div class="max-w-7xl mx-auto">
        <div class="reveal flex items-end justify-between gap-6 flex-wrap mb-11">
          <h2 class="font-display font-black text-[clamp(34px,4.6vw,60px)] leading-[0.96] tracking-[-0.015em] text-blue-black">
            What do you need <em class="italic text-orange">made?</em>
          </h2>
          <p class="text-[15.5px] leading-[1.55] text-blue-black/70 max-w-[330px]">
            From the first sketch to the final render, under one roof. We don't outsource the hard part.
          </p>
        </div>
        <div class="reveal grid grid-cols-2 lg:grid-cols-4 gap-[18px]">
          {needs.map(([no, name, desc], i) => {
            const dark = i % 2 === 1;
            return (
              <div
                data-cursor="link"
                class:list={[
                  'pop-card pop-border pop-shadow-sm rounded-[20px] p-[22px_20px] min-h-[186px] flex flex-col cursor-pointer',
                  dark ? 'bg-skill-blue text-cream' : 'bg-cream text-blue-black',
                ]}
              >
                <span
                  class:list={[
                    'pop-badge self-start text-xs px-2.5 py-1',
                    dark ? 'bg-orange text-blue-black' : 'bg-skill-blue text-cream',
                  ]}
                >
                  {no}
                </span>
                <p class="font-display font-semibold text-[21px] leading-[1.05] mt-4 mb-1.5">{name}</p>
                <p class="text-[12.5px] leading-[1.45] opacity-[0.82]">{desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ══ METHOD TEASER ══ -->
    <section id="method" class="bg-blue-black py-[70px] px-6 lg:px-[46px] border-y-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto grid md:grid-cols-[1.4fr_auto] gap-8 items-center">
        <div class="reveal">
          <h2 class="font-display font-black text-[clamp(30px,4vw,52px)] leading-[0.98] text-cream mb-3">
            Why it works when <em class="italic text-orange">other content doesn't.</em>
          </h2>
          <p class="text-base leading-[1.58] text-cream/72 max-w-[560px]">
            Story, craft, and a bit of science under the hood. There's a method behind
            characters people quote years later.
          </p>
        </div>
        <div class="reveal">
          <a
            href="/methodology/"
            class="pop-btn pop-btn-accent-shadow pop-border inline-block bg-cream text-blue-black text-[15px] font-extrabold px-7 py-[15px] rounded-full"
          >
            How we work →
          </a>
        </div>
      </div>
    </section>

    <!-- ══ CONTACT ══ -->
    <section id="contacto" class="bg-cream py-[90px] px-6 lg:px-[46px] border-t-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-[0.9fr_1.1fr] gap-12 lg:gap-16 items-start">

        <!-- Left: pitch -->
        <div class="reveal">
          <span class="pop-badge-sans pop-border text-xs bg-orange text-blue-black px-4 py-[7px] -rotate-2">Get in touch</span>
          <h2 class="font-display font-black text-[clamp(34px,4.6vw,60px)] leading-[0.94] tracking-[-0.02em] text-blue-black mt-6 mb-4">
            Tell us what you're <em class="italic text-orange">building.</em>
          </h2>
          <p class="text-[15.5px] leading-[1.6] text-blue-black/72 mb-7 max-w-[440px]">
            Share a bit about your project and how we can help. Fields marked with
            <span class="text-orange font-bold">*</span> are required.
          </p>
          <ul class="flex flex-col gap-3.5 mb-8">
            {[
              'Characters, series, games & training — under one roof',
              'Response within one business day',
              'Free first consultation available',
            ].map((line) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-[2px] inline-flex items-center justify-center w-[22px] h-[22px] rounded-full bg-orange border-2 border-blue-black text-blue-black text-[12px] font-black">✓</span>
                <span class="text-[14.5px] leading-[1.5] text-blue-black/80">{line}</span>
              </li>
            ))}
          </ul>
          <p class="text-[14.5px] text-blue-black/70">
            Prefer email? Write to us at <a href="mailto:miguel@emerito.co" class="font-bold text-orange underline underline-offset-2 hover:text-blue-black transition-colors">miguel@emerito.co</a>.
          </p>
        </div>

        <!-- Right: form card -->
        <div class="reveal">
          <div id="home-form-card" class="bg-cream pop-border pop-shadow-lg rounded-[24px] p-6 sm:p-8">
            <form id="home-contact-form" method="POST" action="https://formspree.io/f/xwvdgjey" novalidate>
              <!-- honeypot: bots fill it, humans never see it (Formspree filters _gotcha) -->
              <div class="absolute w-px h-px -left-[9999px] overflow-hidden" aria-hidden="true">
                <label for="home-website">Do not fill this in</label>
                <input type="text" id="home-website" name="_gotcha" tabindex="-1" autocomplete="off" />
              </div>
              <input type="hidden" name="_subject" value="New contact from emerito.co (Home)" />
              <input type="hidden" name="tipo" value="Home page enquiry" />
              <input type="hidden" name="lang" value="en" />

              <div class="grid sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <label for="home-nombre" class="block font-sans font-extrabold uppercase tracking-[0.06em] text-[12.5px] text-blue-black mb-1.5">Name <span class="text-orange">*</span></label>
                  <input type="text" id="home-nombre" name="nombre" required autocomplete="name"
                    class="w-full bg-white border-[2.5px] border-blue-black rounded-[12px] px-3.5 py-2.5 text-[15px] text-blue-black outline-none focus:border-orange" />
                </div>
                <div>
                  <label for="home-email" class="block font-sans font-extrabold uppercase tracking-[0.06em] text-[12.5px] text-blue-black mb-1.5">Email <span class="text-orange">*</span></label>
                  <input type="email" id="home-email" name="email" required autocomplete="email"
                    class="w-full bg-white border-[2.5px] border-blue-black rounded-[12px] px-3.5 py-2.5 text-[15px] text-blue-black outline-none focus:border-orange" />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-4 mb-1">
                <div>
                  <label for="home-empresa" class="block font-sans font-extrabold uppercase tracking-[0.06em] text-[12.5px] text-blue-black mb-1.5">Organization</label>
                  <input type="text" id="home-empresa" name="empresa" autocomplete="organization"
                    class="w-full bg-white border-[2.5px] border-blue-black rounded-[12px] px-3.5 py-2.5 text-[15px] text-blue-black outline-none focus:border-orange" />
                </div>
                <div>
                  <label for="home-phone" class="block font-sans font-extrabold uppercase tracking-[0.06em] text-[12.5px] text-blue-black mb-1.5">Phone</label>
                  <input type="tel" id="home-phone" name="phone" autocomplete="tel"
                    class="w-full bg-white border-[2.5px] border-blue-black rounded-[12px] px-3.5 py-2.5 text-[15px] text-blue-black outline-none focus:border-orange" />
                </div>
              </div>
              <p class="text-[12px] text-blue-black/50 mb-4">Optional — include country / area code when relevant.</p>

              <div class="mb-1">
                <label for="home-mensaje" class="block font-sans font-extrabold uppercase tracking-[0.06em] text-[12.5px] text-blue-black mb-1.5">Message <span class="text-orange">*</span></label>
                <textarea id="home-mensaje" name="mensaje" required rows="4" maxlength="5000"
                  class="w-full bg-white border-[2.5px] border-blue-black rounded-[12px] px-3.5 py-2.5 text-[15px] text-blue-black outline-none focus:border-orange resize-y"></textarea>
              </div>
              <p class="text-[12px] text-blue-black/50 mb-5">Max 5000 characters.</p>

              <p id="home-form-error" class="hidden text-sm text-red-600 mb-4" role="alert"></p>

              <button
                id="home-submit-btn"
                type="submit"
                class="pop-btn pop-border pop-shadow-sm inline-flex items-center gap-2 bg-orange text-blue-black text-[15px] font-extrabold px-7 py-3.5 rounded-full"
              >
                Send message →
              </button>
            </form>
          </div>

          <!-- Success state (swapped in on submit) -->
          <div id="home-form-success" class="hidden bg-cream pop-border pop-shadow-lg rounded-[24px] p-8 text-center">
            <span class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-orange border-[3px] border-blue-black text-blue-black text-2xl font-black mb-4">✓</span>
            <p class="font-display font-black text-[26px] text-blue-black mb-2">Got it — thank you!</p>
            <p class="text-[15px] text-blue-black/70">We'll get back to you within one business day.</p>
          </div>
        </div>

      </div>
    </section>

  </div>

  <script>
    const root = document.querySelector('.pop-root');
    if (root) {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Subtle scroll parallax for elements tagged with data-parallax (e.g. the hero "hi!" badge).
      if (!reduceMotion) {
        const pxEls = Array.from(root.querySelectorAll<HTMLElement>('[data-parallax]')).map((el) => ({
          el,
          speed: parseFloat(el.getAttribute('data-parallax') || '0') || 0,
        }));

        const applyParallax = () => {
          pxEls.forEach(({ el, speed }) => {
            const r = el.getBoundingClientRect();
            const center = r.top + r.height / 2 - window.innerHeight / 2;
            el.style.translate = `0 ${center * speed}px`;
          });
        };

        window.addEventListener('scroll', applyParallax, { passive: true });
        window.addEventListener('resize', applyParallax);
        applyParallax();
      }
    }

    // ── Contact form: submit to the shared API, swap the card for a thank-you on success. ──
    const homeForm = document.getElementById('home-contact-form') as HTMLFormElement | null;
    const homeCard = document.getElementById('home-form-card');
    const homeSuccess = document.getElementById('home-form-success');
    const homeError = document.getElementById('home-form-error');
    const homeSubmit = document.getElementById('home-submit-btn') as HTMLButtonElement | null;

    homeForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!homeForm || !homeSubmit) return;

      homeError?.classList.add('hidden');
      homeSubmit.disabled = true;
      homeSubmit.textContent = 'Sending…';

      try {
        const res = await fetch('https://formspree.io/f/xwvdgjey', {
          method: 'POST',
          body: new FormData(homeForm),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          homeCard?.classList.add('hidden');
          homeSuccess?.classList.remove('hidden');
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'generate_lead', form_name: 'home_page', language: 'en' });
        } else {
          const data = (await res.json().catch(() => ({}))) as { errors?: { message: string }[] };
          if (homeError) {
            homeError.textContent = data.errors?.map((x) => x.message).join(', ') || 'Something went wrong. Please try again.';
            homeError.classList.remove('hidden');
          }
          homeSubmit.disabled = false;
          homeSubmit.textContent = 'Send message →';
        }
      } catch {
        if (homeError) {
          homeError.textContent = 'Connection error. Please try again.';
          homeError.classList.remove('hidden');
        }
        homeSubmit.disabled = false;
        homeSubmit.textContent = 'Send message →';
      }
    });
  </script>
</BaseLayout>
