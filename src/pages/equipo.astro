---
import BaseLayout from '../layouts/BaseLayout.astro';

// El estudio se presenta por disciplinas, no por biografías individuales.
// Miguel (fundador / director creativo) es la única persona nombrada en el sitio.
const disciplines = [
  {
    no: '01',
    name: 'Pensamiento de Futuro',
    sub: 'Leemos el terreno',
    body: 'Antes de hacer cualquier cosa, miramos hacia dónde va la organización — y su audiencia. Qué comportamientos e historias importarán en tres años, no solo este trimestre. Eso mantiene el trabajo relevante mucho después del lanzamiento.',
  },
  {
    no: '02',
    name: 'Ciencia del Comportamiento',
    sub: 'Mapeamos la corriente',
    body: 'Nuestro diagnóstico empieza en campo: observar, preguntar, entender por qué la gente hace lo que hace — no lo que dice que hace. El marco COM-B nos dice exactamente qué palancas debe mover una historia.',
  },
  {
    no: '03',
    name: 'Contenido Creativo',
    sub: 'Trazamos el cauce',
    body: 'Personaje, historia, arquitectura narrativa, dirección visual — el oficio que convierte un hallazgo en algo que la gente realmente ve y siente. Del primer boceto al render final, en casa.',
  },
] as const;
---

<BaseLayout
  title="El estudio"
  description="Emerito es un estudio de contenido creativo en Medellín. Personajes, mundos e historias originales — estrategia, ciencia y oficio bajo un mismo techo."
  lang="es"
  alternateHref="/en/team"
>
  <div class="pop-root relative w-full overflow-hidden">

    <!-- ══ HERO ══ -->
    <section class="bg-ocean py-24 lg:py-32 text-cream border-b-[3px] border-blue-black">
      <div class="max-w-4xl mx-auto px-6 lg:px-8">
        <p class="pop-badge text-xs px-3.5 py-1.5 bg-orange text-blue-black border-[2.5px] border-blue-black mb-6">El estudio</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl leading-[1.05] mb-6">
          Construimos mundos <em class="italic text-orange">desde Medellín.</em>
        </h1>
        <p class="text-xl text-cream/65 leading-relaxed max-w-2xl">
          Emerito es un estudio de contenido creativo. Personajes, historias y mundos
          originales — para marcas que quieren ser recordadas, no solo vistas.
        </p>
      </div>
    </section>

    <!-- ══ THE DREAM & THE COMPANY ══ -->
    <section class="bg-cream py-20 lg:py-28 border-b-[3px] border-blue-black">
      <div class="max-w-4xl mx-auto px-6 lg:px-8 space-y-14">
        <div class="reveal">
          <p class="pop-badge text-xs px-3.5 py-1.5 bg-orange text-blue-black border-[2.5px] border-blue-black mb-6">El sueño</p>
          <h2 class="font-display font-medium text-[clamp(26px,3.2vw,40px)] leading-[1.0] text-blue-black mb-5">
            Personajes que sobreviven <em class="italic text-orange">a la campaña.</em>
          </h2>
          <div class="space-y-4 text-[15.5px] leading-[1.65] text-blue-black/75 max-w-2xl">
            <p>
              La mayoría del contenido de marca muere la semana en que se publica. El contenido
              que la gente realmente ama — las series que cita, los personajes que se tatúa —
              fue construido como un mundo, no como un anuncio. Emerito existe para cerrar esa
              brecha: hacer contenido para empresas con el mismo oficio y cuidado que la
              industria del entretenimiento pone en sus mejores historias.
            </p>
            <p>
              El sueño: un estudio de Medellín cuyos personajes originales vivan en todas partes —
              salas de entrenamiento, feeds, juegos, coleccionables — y sigan trabajando para la
              marca años después del primer episodio.
            </p>
          </div>
        </div>
        <div class="reveal">
          <p class="pop-badge text-xs px-3.5 py-1.5 bg-orange text-blue-black border-[2.5px] border-blue-black mb-6">La empresa</p>
          <h2 class="font-display font-medium text-[clamp(26px,3.2vw,40px)] leading-[1.0] text-blue-black mb-5">
            Un estudio, <em class="italic text-orange">pipeline completo.</em>
          </h2>
          <div class="space-y-4 text-[15.5px] leading-[1.65] text-blue-black/75 max-w-2xl">
            <p>
              Emerito es un estudio independiente fundado en Medellín, Colombia. Todo pasa en
              casa: diseño de personajes, modelado y animación 3D, guion y narrativa, producción
              de video, y los flujos asistidos por IA que mantienen los presupuestos realistas
              sin sacrificar el oficio.
            </p>
            <p>
              Nos mantenemos deliberadamente pequeños y senior. Eso nos permite movernos como un
              laboratorio, comprometernos como un socio, y poner diseño real detrás de cada
              cuadro que entregamos.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ DISCIPLINES ══ -->
    <section class="bg-cream py-20 lg:py-28 border-b-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <h2 class="reveal font-display font-medium text-[clamp(30px,3.8vw,48px)] leading-[0.98] text-blue-black mb-3">
          Tres disciplinas, <em class="italic text-orange">un techo.</em>
        </h2>
        <p class="reveal text-base text-blue-black/65 max-w-xl mb-12">
          La mayoría de los estudios elige una. Construimos Emerito para que la estrategia,
          la ciencia y el oficio nunca se pierdan en un traspaso.
        </p>
        <div class="reveal-stagger grid md:grid-cols-3 gap-6">
          {disciplines.map((d) => (
            <div class="pop-card pop-border pop-shadow-md bg-cream rounded-[22px] p-7">
              <p class="pop-badge text-xs px-2.5 py-1 bg-orange text-blue-black mb-5">{d.no}</p>
              <h3 class="font-display text-[22px] text-blue-black mb-1">{d.name}</h3>
              <p class="font-display italic text-sm text-ocean mb-4">{d.sub}</p>
              <p class="text-sm leading-[1.6] text-blue-black/65">{d.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══ FOUNDER ══ -->
    <section class="bg-orange py-20 lg:py-24 border-b-[3px] border-blue-black">
      <div class="max-w-4xl mx-auto px-6 lg:px-8">
        <p class="reveal pop-badge text-xs px-3.5 py-1.5 bg-cream text-blue-black border-[2.5px] border-blue-black mb-8">
          Dirección creativa
        </p>
        <h2 class="reveal font-display font-medium text-[clamp(28px,3.4vw,42px)] leading-[1.0] text-blue-black mb-5">
          Miguel Zuluaga
        </h2>
        <div class="reveal space-y-4 text-[15.5px] leading-[1.65] text-blue-black/80 max-w-2xl">
          <p>
            Miguel es el fundador, director creativo y productor de Emerito. Su trabajo es tomar
            una idea — o un diagnóstico — y convertirla en algo que la gente realmente ve y
            siente: personajes, historia, arquitectura narrativa y el oficio 3D detrás de todo.
          </p>
          <p>
            Todo lo que ves en este sitio — desde el personaje del inicio hasta la serie de
            entrenamiento del portafolio — fue diseñado, modelado y dirigido en casa, en Medellín.
          </p>
        </div>
      </div>
    </section>

    <!-- ══ HOW WE WORK ══ -->
    <section class="bg-cream py-20 lg:py-24">
      <div class="max-w-3xl mx-auto px-6 lg:px-8">
        <p class="pop-badge text-xs px-3.5 py-1.5 bg-orange text-blue-black border-[2.5px] border-blue-black mb-10">Cómo trabajamos</p>
        <ul class="space-y-5">
          <li class="flex gap-5">
            <span class="text-orange text-lg leading-none flex-shrink-0 mt-0.5">·</span>
            <div>
              <p class="font-semibold text-blue-black mb-1">Iteración con el cliente</p>
              <p class="text-sm text-blue-black/60 leading-relaxed">Trabajamos en sprints cortos con validación frecuente. Nunca desaparecemos seis semanas para volver con algo que no querías.</p>
            </div>
          </li>
          <li class="flex gap-5">
            <span class="text-orange text-lg leading-none flex-shrink-0 mt-0.5">·</span>
            <div>
              <p class="font-semibold text-blue-black mb-1">Entender antes de producir</p>
              <p class="text-sm text-blue-black/60 leading-relaxed">No producimos antes de entender el problema. Eso puede incomodar si ya tenés el video en mente — pero es lo que hace que el resultado funcione.</p>
            </div>
          </li>
          <li class="flex gap-5">
            <span class="text-orange text-lg leading-none flex-shrink-0 mt-0.5">·</span>
            <div>
              <p class="font-semibold text-blue-black mb-1">Transparencia de precios</p>
              <p class="text-sm text-blue-black/60 leading-relaxed">Las propuestas son claras y detalladas. Nada crece en silencio. Si hay un cambio de alcance, lo nombramos antes de ejecutarlo.</p>
            </div>
          </li>
          <li class="flex gap-5">
            <span class="text-orange text-lg leading-none flex-shrink-0 mt-0.5">·</span>
            <div>
              <p class="font-semibold text-blue-black mb-1">Medición de resultados</p>
              <p class="text-sm text-blue-black/60 leading-relaxed">Cuando el cliente nos da acceso a datos de campo, medimos. No prometemos métricas que no podemos controlar, pero sí nos comprometemos a aprender del resultado.</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <!-- ══ CTA ══ -->
    <section class="bg-ocean py-24 text-center border-t-[3px] border-blue-black">
      <div class="max-w-xl mx-auto px-6 lg:px-8">
        <h2 class="text-2xl text-cream mb-5">¿Trabajamos <em class="italic text-orange">juntos?</em></h2>
        <a href="/contacto/" class="pop-btn pop-border pop-shadow-md inline-block bg-orange text-blue-black text-sm font-extrabold px-8 py-4 rounded-full">
          Hablemos →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
