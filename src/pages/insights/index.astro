---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) =>
  data.lang === 'es' && !data.draft
);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Insights"
  description="Notas sobre cambio de comportamiento, futuro empresarial y comunicación creativa."
  lang="es"
  alternateHref="/en/insights"
>

  <!-- ─── HERO ───────────────────────────────────────────────────── -->
  <section class="bg-cream py-24 lg:py-28 border-b-[3px] border-blue-black">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <p class="pop-badge text-xs px-3.5 py-1.5 bg-orange text-blue-black border-[2.5px] border-blue-black mb-6">
        Insights
      </p>
      <h1 class="text-4xl sm:text-5xl text-blue-black leading-[1.05] mb-6">
        Insights
      </h1>
      <p class="text-lg text-blue-black/65 leading-relaxed max-w-2xl">
        Notas sobre cambio de comportamiento, futuro empresarial y comunicación creativa.
      </p>
    </div>
  </section>

  <!-- ─── POST GRID ─────────────────────────────────────────────── -->
  <section class="bg-cream py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      {posts.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map(post => (
            <article class="pop-tile">
              <a href={`/insights/${post.id}`} class="block group">
                <figure class="pop-card pop-border pop-shadow-sm rounded-[16px] aspect-video overflow-hidden bg-ocean mb-4 m-0">
                  {post.data.cover ? (
                    <img
                      src={post.data.cover}
                      alt={post.data.title}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full bg-orange/10"></div>
                  )}
                </figure>
              </a>
              <p class="pop-badge text-[10px] px-2.5 py-1 bg-orange text-blue-black mb-2">
                {post.data.category}
              </p>
              <h2 class="text-lg font-bold text-blue-black leading-snug mb-2">
                <a href={`/insights/${post.id}`} class="hover:text-orange transition-colors">
                  {post.data.title}
                </a>
              </h2>
              <p class="font-mono text-xs text-blue-black/40 mb-2">
                {post.data.pubDate.toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <p class="text-sm text-blue-black/60 leading-relaxed">{post.data.description}</p>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-blue-black/40 text-sm mb-4">Próximos artículos en camino.</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
