---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto" lang="es">
  <section class="px-6 py-24 max-w-2xl mx-auto">
    <p class="text-sm font-semibold text-current uppercase tracking-widest mb-4">Contacto — Paso 3/4</p>
    <h1 class="text-4xl font-bold text-ocean mb-4">Hablemos.</h1>
    <p class="text-lg text-ink/70 mb-8">Cuéntanos sobre tu proyecto. Respondemos en menos de 48 horas.</p>
    <p class="text-ink/50 italic">Formulario completo en el Paso 3. Integración con Resend en el Paso 4.</p>
  </section>
</BaseLayout>
