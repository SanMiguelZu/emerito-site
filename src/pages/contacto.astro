---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto"
  description="Hablemos sobre tu proyecto. Respondemos en menos de 48 horas."
  lang="es"
  alternateHref="/en/contact"
>

  <section class="bg-cream py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24">

      <!-- Left: heading -->
      <div class="lg:pt-2">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl text-blue-black leading-[1.05] mb-6">
          <span class="italic text-orange">Hablemos.</span>
        </h1>
        <p class="text-lg text-blue-black/65 leading-relaxed mb-10">
          Cuéntanos sobre tu proyecto. Respondemos en menos de 48 horas.
        </p>
        <div class="space-y-4 text-sm text-blue-black/55">
          <p>
            O escríbenos directamente a{' '}
            <a href="mailto:miguel@emerito.co" class="text-blue-black font-semibold hover:text-orange transition-colors">
              miguel@emerito.co
            </a>
          </p>
          <p>Medellín, Colombia</p>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <!-- Success state (shown by JS after successful submission — Step 4) -->
        <div
          id="form-success"
          class="hidden pop-border pop-shadow-sm bg-orange/10 rounded-[18px] p-8 text-center"
          role="alert"
        >
          <p class="text-blue-black font-bold text-lg mb-2">Gracias.</p>
          <p class="text-blue-black/70 text-sm">Te respondemos en menos de 48 horas.</p>
        </div>

        <!-- Contact form — backend wired in Step 4 -->
        <form
          id="contact-form"
          method="POST"
          action="https://formspree.io/f/xwvdgjey"
          class="space-y-6"
          novalidate
        >
          <input type="hidden" name="_subject" value="Nuevo contacto desde emerito.co (Contacto)" />
          <input type="hidden" name="lang" value="es" />
          <!-- Honeypot (Formspree filtra _gotcha) -->
          <div class="hidden" aria-hidden="true">
            <label for="website">No completar</label>
            <input type="text" id="website" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>

          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="nombre" class="block font-mono text-xs font-semibold text-blue-black/60 uppercase tracking-widest mb-2">
                Nombre <span class="text-orange">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                autocomplete="name"
                class="w-full bg-cream border-2 border-blue-black/30 rounded-[10px] px-4 py-3 text-sm text-blue-black placeholder-blue-black/30 focus:outline-none focus:border-orange transition-colors"
                placeholder="Tu nombre"
              />
            </div>
            <div>
              <label for="email" class="block font-mono text-xs font-semibold text-blue-black/60 uppercase tracking-widest mb-2">
                Email <span class="text-orange">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full bg-cream border-2 border-blue-black/30 rounded-[10px] px-4 py-3 text-sm text-blue-black placeholder-blue-black/30 focus:outline-none focus:border-orange transition-colors"
                placeholder="tu@empresa.com"
              />
            </div>
          </div>

          <div>
            <label for="empresa" class="block font-mono text-xs font-semibold text-blue-black/60 uppercase tracking-widest mb-2">
              Empresa <span class="text-blue-black/35 font-normal normal-case tracking-normal">(opcional)</span>
            </label>
            <input
              type="text"
              id="empresa"
              name="empresa"
              autocomplete="organization"
              class="w-full bg-cream border-2 border-blue-black/30 rounded-[10px] px-4 py-3 text-sm text-blue-black placeholder-blue-black/30 focus:outline-none focus:border-orange transition-colors"
              placeholder="Nombre de tu empresa"
            />
          </div>

          <div>
            <label for="tipo" class="block font-mono text-xs font-semibold text-blue-black/60 uppercase tracking-widest mb-2">
              Tipo de proyecto <span class="text-orange">*</span>
            </label>
            <select
              id="tipo"
              name="tipo"
              required
              class="w-full bg-cream border-2 border-blue-black/30 rounded-[10px] px-4 py-3 text-sm text-blue-black focus:outline-none focus:border-orange transition-colors appearance-none"
            >
              <option value="" disabled selected>Seleccioná una opción</option>
              <option value="insight">Diagnóstico (Cauce Insight)</option>
              <option value="studio">Producción completa (Cauce Studio)</option>
              <option value="unsure">No estoy seguro/a</option>
              <option value="other">Otro</option>
            </select>
          </div>

          <div>
            <label for="mensaje" class="block font-mono text-xs font-semibold text-blue-black/60 uppercase tracking-widest mb-2">
              Cuéntanos sobre tu proyecto <span class="text-orange">*</span>
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows="5"
              class="w-full bg-cream border-2 border-blue-black/30 rounded-[10px] px-4 py-3 text-sm text-blue-black placeholder-blue-black/30 focus:outline-none focus:border-orange transition-colors resize-none"
              placeholder="¿Qué comportamiento querés cambiar? ¿En qué contexto? ¿Qué ha intentado tu empresa hasta ahora?"
            ></textarea>
          </div>

          <!-- Error message (shown by Step 4 JS on failure) -->
          <p id="form-error" class="hidden text-sm text-red-600" role="alert"></p>

          <button
            type="submit"
            id="submit-btn"
            class="pop-btn pop-border pop-shadow-sm w-full bg-orange text-blue-black text-sm font-extrabold px-6 py-4 rounded-full disabled:opacity-50"
          >
            Enviar
          </button>

          <p class="text-xs text-blue-black/40 text-center">
            La primera conversación es gratuita y sin compromiso.
          </p>
        </form>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successBox = document.getElementById('form-success');
  const errorBox = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    errorBox?.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando…';

    try {
      const res = await fetch('https://formspree.io/f/xwvdgjey', {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.classList.add('hidden');
        successBox?.classList.remove('hidden');
      } else {
        const data = await res.json().catch(() => ({})) as { errors?: { message: string }[] };
        if (errorBox) {
          errorBox.textContent = data.errors?.map((x) => x.message).join(', ') || 'Algo salió mal. Intentá de nuevo.';
          errorBox.classList.remove('hidden');
        }
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar';
      }
    } catch {
      if (errorBox) {
        errorBox.textContent = 'Error de conexión. Intentá de nuevo.';
        errorBox.classList.remove('hidden');
      }
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar';
    }
  });
</script>
