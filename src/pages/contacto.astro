---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto"
  description="Hablemos sobre tu proyecto. Respondemos en menos de 48 horas."
  lang="es"
  alternateHref="/en/contact"
>

  <section class="bg-sand py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24">

      <!-- Left: heading -->
      <div class="lg:pt-2">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-ocean leading-[1.05] mb-6">
          Hablemos.
        </h1>
        <p class="text-lg text-ink/60 leading-relaxed mb-10">
          Cuéntanos sobre tu proyecto. Respondemos en menos de 48 horas.
        </p>
        <div class="space-y-4 text-sm text-ink/50">
          <p>
            O escríbenos directamente a{' '}
            <a href="mailto:michael@emerito.co" class="text-ocean hover:text-accent transition-colors font-medium">
              michael@emerito.co
            </a>
          </p>
          <p>Medellín, Colombia</p>
        </div>
      </div>

      <!-- Right: form -->
      <div>
        <!-- Success state (shown by JS after successful submission — Step 4) -->
        <div
          id="form-success"
          class="hidden bg-cream border border-ink/10 rounded-sm p-8 text-center"
          role="alert"
        >
          <p class="text-ocean font-semibold text-lg mb-2">Gracias.</p>
          <p class="text-ink/65 text-sm">Te respondemos en menos de 48 horas.</p>
        </div>

        <!-- Contact form — backend wired in Step 4 -->
        <form
          id="contact-form"
          method="POST"
          action="/api/contact"
          class="space-y-6"
          novalidate
        >
          <!-- Honeypot (hidden from real users, catches bots) -->
          <div class="hidden" aria-hidden="true">
            <label for="website">No completar</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="nombre" class="block text-xs font-semibold text-ink/60 uppercase tracking-widest mb-2">
                Nombre <span class="text-ocean">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                autocomplete="name"
                class="w-full bg-white border border-ink/15 rounded-sm px-4 py-3 text-sm text-ink placeholder-ink/30 focus:outline-none focus:border-ocean transition-colors"
                placeholder="Tu nombre"
              />
            </div>
            <div>
              <label for="email" class="block text-xs font-semibold text-ink/60 uppercase tracking-widest mb-2">
                Email <span class="text-ocean">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full bg-white border border-ink/15 rounded-sm px-4 py-3 text-sm text-ink placeholder-ink/30 focus:outline-none focus:border-ocean transition-colors"
                placeholder="tu@empresa.com"
              />
            </div>
          </div>

          <div>
            <label for="empresa" class="block text-xs font-semibold text-ink/60 uppercase tracking-widest mb-2">
              Empresa <span class="text-ink/30 font-normal normal-case tracking-normal">(opcional)</span>
            </label>
            <input
              type="text"
              id="empresa"
              name="empresa"
              autocomplete="organization"
              class="w-full bg-white border border-ink/15 rounded-sm px-4 py-3 text-sm text-ink placeholder-ink/30 focus:outline-none focus:border-ocean transition-colors"
              placeholder="Nombre de tu empresa"
            />
          </div>

          <div>
            <label for="tipo" class="block text-xs font-semibold text-ink/60 uppercase tracking-widest mb-2">
              Tipo de proyecto <span class="text-ocean">*</span>
            </label>
            <select
              id="tipo"
              name="tipo"
              required
              class="w-full bg-white border border-ink/15 rounded-sm px-4 py-3 text-sm text-ink focus:outline-none focus:border-ocean transition-colors appearance-none"
            >
              <option value="" disabled selected>Seleccioná una opción</option>
              <option value="insight">Diagnóstico (Cauce Insight)</option>
              <option value="studio">Producción completa (Cauce Studio)</option>
              <option value="unsure">No estoy seguro/a</option>
              <option value="other">Otro</option>
            </select>
          </div>

          <div>
            <label for="mensaje" class="block text-xs font-semibold text-ink/60 uppercase tracking-widest mb-2">
              Cuéntanos sobre tu proyecto <span class="text-ocean">*</span>
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows="5"
              class="w-full bg-white border border-ink/15 rounded-sm px-4 py-3 text-sm text-ink placeholder-ink/30 focus:outline-none focus:border-ocean transition-colors resize-none"
              placeholder="¿Qué comportamiento querés cambiar? ¿En qué contexto? ¿Qué ha intentado tu empresa hasta ahora?"
            ></textarea>
          </div>

          <!-- Error message (shown by Step 4 JS on failure) -->
          <p id="form-error" class="hidden text-sm text-red-600" role="alert"></p>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-ocean text-sand text-sm font-semibold px-6 py-4 rounded-sm hover:bg-ocean/85 transition-colors disabled:opacity-50"
          >
            Enviar
          </button>

          <p class="text-xs text-ink/35 text-center">
            La primera conversación es gratuita y sin compromiso.
          </p>
        </form>
      </div>

    </div>
  </section>

</BaseLayout>

<!-- Step 4: wire submit handler here — see src/pages/api/contact.ts -->
