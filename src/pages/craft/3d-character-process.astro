---
import BaseLayout from '../../layouts/BaseLayout.astro';

// The 3D character process, shown through Emerito's yellow frog (kept unnamed).
const stages = [
  {
    no: '01',
    title: 'Concept & exploration',
    desc: 'Every character starts as a question: who is this, and what do they stand for? It begins as pages of options — silhouettes, color tests, and attitudes — until one design refuses to be discarded.',
    media: [
      { type: 'img', src: '/images/Personajes/YellowFrog/Sanmiguel Zu_Noise_Low.webp', alt: 'Yellow frog character concept illustration', caption: 'Concept art', fit: 'natural' },
    ],
  },
  {
    no: '02',
    title: '3D modeling',
    desc: 'From flat sketch to a sculpted, watertight mesh. Clean topology — the geometry flow of the model — decides whether a face can smile without breaking. Boring to look at, impossible to skip.',
    media: [
      { type: 'img', src: '/images/Personajes/YellowFrog/Topology.jpg', alt: '3D model topology wireframe', caption: 'Wireframe', fit: 'natural' },
    ],
  },
  {
    no: '03',
    title: 'Texturing',
    desc: 'Color, material, and surface detail turn a grey model into a character — the exact yellow, the exact charm, consistent from every angle and every light.',
    media: [
      { type: 'img', src: '/images/Personajes/YellowFrog/Poses3.jpg', alt: 'Character color and texture sheet', caption: 'Texturing', fit: 'natural' },
    ],
  },
  {
    no: '04',
    title: 'Turntable',
    desc: 'The rite of passage for every 3D character: a full rotation under neutral light. No angle to hide in.',
    media: [
      { type: 'video', src: '/images/Personajes/YellowFrog/turntable.mp4', caption: 'Turntable' },
    ],
  },
] as const;
---

<BaseLayout
  title="3D Character Design Process: Concept to Animation"
  description="The 3D character design process step by step — concept art, pose sheets, topology, look development, turntable renders, and character animation — from Emerito, an animation studio in Medellín."
  lang="en"
  alternateHref="/es/oficio/proceso-de-personaje-3d"
>
  <div class="pop-root relative w-full overflow-hidden">

    <!-- ══ HEADER ══ -->
    <section class="bg-cream pt-20 pb-14 px-6 lg:px-[46px] border-b-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto">
        <a href="/" class="pop-nav-link inline-block font-mono text-[12px] font-bold tracking-[0.08em] uppercase text-blue-black/55 mb-7">← Home</a>
        <p class="pop-badge text-xs px-3.5 py-1.5 bg-orange text-blue-black border-[2.5px] border-blue-black mb-6">Character process</p>
        <h1 class="font-display font-medium text-[clamp(40px,5.6vw,84px)] leading-[0.9] tracking-[-0.025em] text-blue-black mb-6">
          How a 3D character <em class="italic text-orange">comes to life.</em>
        </h1>
        <p class="text-lg leading-[1.6] text-blue-black/70 max-w-[620px]">
          A look at our full character design process, from first sketch to final spin:
          concept, 3D modeling, texturing, and turntable. The same pipeline behind every
          character we ship.
        </p>
      </div>
    </section>

    <!-- ══ STAGES ══ -->
    <section class="bg-cream py-[80px] px-6 lg:px-[46px]">
      <div class="max-w-7xl mx-auto flex flex-col gap-[90px]">
        {stages.map((s, i) => (
          <article class:list={['grid gap-10 items-center', 'lg:grid-cols-[0.9fr_1.1fr]']}>
            <div class:list={['reveal', i % 2 === 1 ? 'lg:order-2' : '']}>
              <span class="pop-badge text-xs px-3 py-1 bg-blue-black text-cream">Stage {s.no}</span>
              <h2 class="font-display font-medium text-[clamp(26px,3.4vw,44px)] leading-[1] text-blue-black mt-4 mb-4">{s.title}</h2>
              <p class="text-[16px] leading-[1.6] text-blue-black/75 max-w-[520px]">{s.desc}</p>
            </div>
            <div class:list={['reveal grid gap-5', s.media.length > 1 ? 'sm:grid-cols-2' : '', i % 2 === 1 ? 'lg:order-1' : '']}>
              {s.media.map((m) => (
                <figure class="pop-card pop-tile pop-border pop-shadow-md m-0 rounded-[20px] overflow-hidden bg-ocean relative">
                  {m.type === 'video' ? (
                    <video src={m.src} autoplay muted loop playsinline class="w-full aspect-[4/3] object-cover"></video>
                  ) : (
                    <img src={m.src} alt={m.alt ?? ''} class:list={['w-full', 'fit' in m && m.fit === 'natural' ? 'h-auto' : 'aspect-[4/3] object-cover']} loading="lazy" />
                  )}
                  <span class="font-mono absolute bottom-3 left-3.5 text-[10px] font-bold tracking-[0.08em] uppercase text-cream/80 bg-blue-black/60 rounded-full px-2.5 py-1">{m.caption}</span>
                </figure>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ══ CTA ══ -->
    <section class="bg-orange py-[80px] px-6 lg:px-[46px] text-center border-t-[3px] border-blue-black">
      <div class="max-w-[680px] mx-auto">
        <h2 class="font-display font-medium text-[clamp(30px,4.2vw,54px)] leading-[0.98] text-blue-black mb-4">
          Your brand deserves <em class="italic">a face like this.</em>
        </h2>
        <p class="text-[16px] leading-[1.6] text-blue-black/75 mb-8">
          Original character design, full IP, and the whole pipeline under one roof.
        </p>
        <a
          href="/#contacto"
          data-cursor="cta"
          class="pop-btn pop-border inline-block bg-blue-black text-cream text-[16px] font-extrabold px-8 py-4 rounded-full"
          style="box-shadow: 7px 7px 0 #FFF6E4;"
        >
          Let's design yours →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
