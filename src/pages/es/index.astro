---
import BaseLayout from '../../layouts/BaseLayout.astro';

// ── Lo que hacemos: los cuatro proyectos principales, cada uno a su página. ──
const products = [
  {
    label: 'Serie de formación',
    title: 'Zero Risk Zone',
    desc: 'Una serie con personajes para cuadrillas que se duermen en las capacitaciones de seguridad.',
    href: '/es/trabajo/zero-risk-zone/',
    media: { type: 'img', src: '/images/Proyecto 1-Trabajo_Seguro_En_Alturas-AI/Zero Risk Zone_Banner.webp', alt: 'Banner de la serie de formación Zero Risk Zone' },
  },
  {
    label: 'Juegos y experiencias',
    title: 'Palmódromo Medellín',
    desc: 'Narrativa urbana de carreras por las calles de Medellín.',
    href: '/es/trabajo/palmodromo-medellin/',
    media: { type: 'video', src: '/images/Palmodromo/DriftRender.mp4' },
  },
  {
    label: 'Experimentos',
    title: 'El Lab',
    desc: 'Experimentos rápidos de creación de contenido en 3D, IA y código.',
    href: '/es/lab/',
    media: { type: 'video', src: '/images/LAB/CatWalk_V020001-0109.mp4' },
  },
  {
    label: 'Coleccionables · Crédito de equipo',
    title: 'Bacano Go!',
    desc: 'El Carnaval de Barranquilla como coleccionables digitales.',
    href: '/es/trabajo/bacano-go/',
    media: { type: 'img', src: '/images/Bacano Go/Carnaval_Banner_HomePage.webp', alt: 'Personajes del carnaval de Bacano Go!' },
  },
] as const;

// ── El método: tres disciplinas, un cauce. ──
const pillars = [
  {
    no: '01',
    name: 'Pensamiento de Futuro',
    sub: 'Leemos el terreno',
    desc: 'Entendemos hacia dónde va la organización y qué comportamientos importarán en tres años.',
    color: 'var(--color-ocean)',
  },
  {
    no: '02',
    name: 'Ciencia del Comportamiento',
    sub: 'Mapeamos la corriente',
    desc: 'Diagnosticamos el problema real con COM-B: capacidades, oportunidades y motivaciones.',
    color: 'var(--color-orange)',
  },
  {
    no: '03',
    name: 'Contenido Creativo',
    sub: 'Trazamos el cauce',
    desc: 'Construimos la intervención: el personaje, la historia, el video que cambia la forma de actuar.',
    color: 'var(--color-ocean)',
  },
] as const;

// ── Lo que los clientes vienen a buscar: necesidades primero, keywords haciendo el SEO. ──
const needs = [
  ['01', 'Videos de formación', 'Contenido de seguridad y cumplimiento que tus equipos realmente ven, recuerdan y aplican.'],
  ['02', 'Personajes de marca y mascotas', 'Diseño de personajes originales con IP completa: una cara que tu audiencia reconoce donde sea.'],
  ['03', 'Animación 3D', 'Animación de personajes, renders de producto y simulaciones con oficio real detrás.'],
  ['04', 'Producción asistida por IA', 'Pipelines modernos que mantienen la calidad alta y los presupuestos realistas.'],
  ['05', 'Sistemas de contenido social', 'Personajes, plantillas y stickers que tu equipo sí puede mantener al día.'],
  ['06', 'Juegos e interactivo', 'Juegos y experiencias narrativas en las que la gente entra, no que scrollea de largo.'],
  ['07', 'Producción de video', 'Del guion a la pantalla: rodaje, edición y post.'],
  ['08', 'Estrategia de contenido', 'Qué hacer, para quién y por qué se va a quedar.'],
] as const;
---

<BaseLayout
  title="Estudio de contenido creativo"
  description="Emerito es un estudio de contenido creativo en Medellín. Personajes de marca originales, series animadas, juegos, experiencias y contenido de formación que se comporta como entretenimiento."
  lang="es"
  alternateHref="/"
>
  <div class="pop-root relative w-full overflow-hidden">

    <!-- ══ HERO ══ -->
    <section class="relative bg-cream overflow-hidden border-b-[3px] border-blue-black">
      <div class="max-w-[1320px] mx-auto px-6 lg:px-[46px] grid lg:grid-cols-[1.04fr_0.96fr] gap-8 items-stretch lg:min-h-[640px] lg:h-[calc(100vh-66px)]">
        <!-- mensaje izquierda -->
        <div class="py-16 lg:py-0 flex flex-col justify-center relative z-[3]">
          <p class="inline-flex items-center gap-2.5 font-sans font-extrabold text-[12.5px] tracking-[0.09em] uppercase text-blue-black mb-6">
            <span class="inline-block bg-orange border-2 border-blue-black rounded-full px-3 py-1">Medellín, CO</span>
            Estudio de contenido creativo
          </p>
          <h1 class="font-display font-medium text-[clamp(44px,5.8vw,88px)] leading-[0.9] tracking-[-0.03em] text-blue-black mb-6">
            Dale a tu mensaje un <em class="italic text-orange">personaje</em> que la gente recuerde.
          </h1>
          <p class="text-lg leading-[1.55] text-blue-black/75 mb-8 max-w-[470px]">
            Emerito es un estudio de contenido creativo en Medellín. Personajes de marca, series
            animadas, juegos y contenido de formación que la gente realmente <strong>ve, recuerda y aplica.</strong>
          </p>
          <div class="flex gap-3.5 flex-wrap">
            <a
              href="/es/trabajo/"
              data-cursor="cta"
              class="pop-btn pop-border pop-shadow-sm inline-flex items-center gap-2.5 bg-orange text-blue-black text-[15px] font-extrabold px-7 py-4 rounded-full"
            >
              Explora el trabajo →
            </a>
            <a
              href="/es/#contacto"
              data-cursor="link"
              class="pop-btn pop-border pop-shadow-sm bg-cream text-blue-black text-[15px] font-extrabold px-6 py-4 rounded-full"
            >
              Hablemos
            </a>
          </div>
        </div>
        <!-- derecha: personaje parado en el bloque azul, mirando el mensaje -->
        <div class="relative flex items-end justify-center overflow-hidden min-h-[380px] lg:min-h-0">
          <div class="absolute left-1/2 bottom-0 -translate-x-1/2 w-[min(100%,520px)] h-[82%] bg-ocean border-[3px] border-b-0 border-blue-black rounded-t-[44px] overflow-hidden">
            <div
              class="absolute inset-0 opacity-35"
              style="background-image: radial-gradient(#FFF6E4 1.3px, transparent 1.3px); background-size: 26px 26px;"
            ></div>
          </div>
          <span
            class="pop-hide-sm absolute top-[14%] right-[6%] font-display italic font-semibold text-[28px] text-cream bg-orange border-[2.5px] border-blue-black rounded-full px-4 py-1 rotate-[7deg] z-[3]"
            data-parallax="-0.1"
          >
            ¡hola!
          </span>
          <img
            id="pop-rana"
            src="/images/Personajes/YellowFrog/RanaNoBg_Flipped.webp"
            alt="La rana amarilla de Emerito"
            class="relative z-[2] h-[min(90%,780px)] self-end animate-[pop-float_6.5s_ease-in-out_infinite]"
            style="filter: drop-shadow(0 22px 26px rgba(6,34,47,.3));"
          />
        </div>
      </div>
    </section>

    <!-- ══ MARQUEE ══ -->
    <div class="bg-blue-black overflow-hidden py-4 border-b-[3px] border-blue-black">
      <div class="flex w-max animate-[pop-marquee_26s_linear_infinite]">
        {[0, 1].map((i) => (
          <span class="flex items-center font-mono font-semibold text-lg tracking-[0.14em] text-cream" aria-hidden={i === 1 ? 'true' : undefined}>
            <span class="px-6">LABORATORIO CREATIVO</span><span class="text-orange">✦</span>
            <span class="px-6">NARRATIVA</span><span class="text-orange">✦</span>
            <span class="px-6">IA PARA CREAR CONTENIDO</span><span class="text-orange">✦</span>
            <span class="px-6">DISEÑAMOS MUNDOS PARA CONTAR HISTORIAS</span><span class="text-orange">✦</span>
          </span>
        ))}
      </div>
    </div>

    <!-- ══ PROYECTOS PRINCIPALES ══ -->
    <section id="worlds" class="bg-cream py-[90px] px-6 lg:px-[46px]">
      <div class="max-w-7xl mx-auto">
        <div class="reveal flex items-baseline gap-6 flex-wrap mb-11">
          <h2 class="font-display font-black text-[clamp(52px,7vw,110px)] leading-[0.86] tracking-[-0.03em] text-blue-black">
            Mundos que hemos <em class="italic text-orange">construido.</em>
          </h2>
          <span class="pop-badge-sans pop-border text-xs bg-ocean text-cream px-4 py-[7px] -rotate-3">Trabajo real, publicado ✦</span>
        </div>
        <div class="reveal grid sm:grid-cols-2 gap-6">
          {products.map((p) => (
            <a
              href={p.href}
              data-cursor="cta"
              class="pop-card pop-tile pop-border pop-shadow-md block rounded-[22px] overflow-hidden bg-cream"
            >
              <div class="overflow-hidden bg-ocean relative aspect-[16/10]">
                {p.media.type === 'video' ? (
                  <video src={p.media.src} autoplay muted loop playsinline class="w-full h-full object-cover"></video>
                ) : (
                  <img src={p.media.src} alt={'alt' in p.media ? p.media.alt : ''} class="w-full h-full object-cover" />
                )}
                <span class="pop-badge-sans absolute top-3.5 left-3.5 text-[10px] px-2.5 py-1 bg-orange text-blue-black -rotate-3">{p.label}</span>
              </div>
              <div class="p-[16px_20px_18px]">
                <p class="font-display italic font-bold text-[27px] leading-[1.05] text-blue-black mb-1">{p.title}</p>
                <p class="text-[13.5px] leading-[1.5] text-blue-black/58">{p.desc} →</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ══ TRES DISCIPLINAS ══ -->
    <section id="metodo" class="bg-orange py-[90px] px-6 lg:px-[46px] border-y-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto">
        <h2 class="reveal text-center font-display font-black text-[clamp(32px,4.4vw,56px)] leading-[0.98] text-blue-black mb-2">
          Hay una <em class="italic">ciencia</em> detrás del contenido que la gente recuerda.
        </h2>
        <p class="reveal text-center text-base text-blue-black/72 mb-11">
          Cómo convertimos un problema en un cambio real.
        </p>
        <div class="reveal-stagger grid md:grid-cols-3 gap-5">
          {pillars.map((p) => (
            <div class="pop-card pop-border pop-shadow-md bg-cream rounded-[24px] p-[30px_26px_28px]">
              <p
                class="font-display italic font-bold text-[56px] leading-[0.8] mb-[18px]"
                style={`color:${p.color}; -webkit-text-stroke: 2px #06222F;`}
              >
                {p.no}
              </p>
              <h3 class="font-display font-medium text-[23px] text-blue-black mb-1">{p.name}</h3>
              <p class="font-display italic text-sm text-ocean mb-3.5">{p.sub}</p>
              <p class="text-[14.5px] leading-[1.58] text-blue-black/74">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══ DETRÁS DEL OFICIO ══ -->
    <section id="craft" class="bg-blue-black py-[90px] px-6 lg:px-[46px] border-y-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto">
        <div class="reveal grid lg:grid-cols-[1.3fr_1fr] gap-9 items-end mb-11">
          <h2 class="font-display font-black text-[clamp(34px,4.6vw,60px)] leading-[0.96] text-cream">
            Detrás del <em class="italic text-orange">oficio.</em>
          </h2>
          <p class="text-[15px] leading-[1.58] text-cream/72">
            Cómo se hace el trabajo: pipelines de personajes, storyboards, simulaciones
            y los flujos que estamos probando.
          </p>
        </div>
        <div class="reveal grid grid-cols-1 lg:grid-cols-[1fr_1.1fr] gap-6 items-stretch">
          <!-- Izquierda: cuadro grande, video turntable, ocupa toda la altura de columna -->
          <a href="/es/oficio/proceso-de-personaje-3d/" class="pop-card pop-tile pop-border pop-shadow-md flex flex-col rounded-[22px] overflow-hidden bg-skill-blue">
            <div class="flex-1 min-h-[340px] overflow-hidden bg-ocean relative">
              <video src="/images/Personajes/YellowFrog/turntable.mp4" autoplay muted loop playsinline class="w-full h-full object-cover"></video>
              <span class="pop-badge-sans absolute top-3.5 left-3.5 text-[10px] px-2.5 py-1 bg-orange text-blue-black">Proceso de personaje</span>
            </div>
            <div class="p-[16px_20px_18px]">
              <p class="font-display italic font-bold text-[24px] leading-[1.05] text-cream mb-1">Cómo cobra vida un personaje 3D.</p>
              <p class="text-[13.5px] leading-[1.5] text-cream/58">Del primer boceto al ciclo de caminado: todo el proceso de personaje 3D, documentado. →</p>
            </div>
          </a>
          <!-- Derecha: dos cajas anchas apiladas, bordes inferiores alineados con el cuadro izquierdo -->
          <div class="flex flex-col gap-6 h-full">
            <a href="/es/lab/" class="pop-card pop-tile pop-border pop-shadow-md flex flex-col rounded-[22px] overflow-hidden bg-skill-blue">
              <div class="aspect-[5/2] overflow-hidden bg-ocean relative">
                <img src="/images/Proyecto 1-Trabajo_Seguro_En_Alturas-AI/Sketch_Storyboard.webp" alt="Bocetos de storyboard" class="w-full h-full object-cover" loading="lazy" />
                <span class="pop-badge-sans absolute top-3.5 left-3.5 text-[10px] px-2.5 py-1 bg-orange text-blue-black">El lab</span>
              </div>
              <div class="p-[16px_20px_18px]">
                <p class="font-display italic font-bold text-[24px] leading-[1.05] text-cream mb-1">Notas sobre el oficio</p>
                <p class="text-[13.5px] leading-[1.5] text-cream/58">Storyboards, simulación, flujos con IA y lo que aprendemos haciendo cosas. →</p>
              </div>
            </a>
            <a href="/es/insights/la-industria-de-animacion-de-medellin-en-transicion/" class="pop-card pop-tile pop-border pop-shadow-md flex flex-col rounded-[22px] overflow-hidden bg-skill-blue">
              <div class="aspect-[5/2] overflow-hidden bg-ocean relative">
                <img src="/images/Blogs/Animation Industry in Transition.webp" alt="La industria de animación de Medellín en transición" class="w-full h-full object-cover" loading="lazy" />
                <span class="pop-badge-sans absolute top-3.5 left-3.5 text-[10px] px-2.5 py-1 bg-orange text-blue-black">Del blog</span>
              </div>
              <div class="p-[16px_20px_18px]">
                <p class="font-display italic font-bold text-[24px] leading-[1.05] text-cream mb-1">La industria de animación de Medellín en transición</p>
                <p class="text-[13.5px] leading-[1.5] text-cream/58">Lo que la IA está transformando a nivel de estudio, y lo que perdemos en el camino. →</p>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ QUÉ NECESITAS ══ -->
    <section id="lab" class="bg-cream py-[90px] px-6 lg:px-[46px]">
      <div class="max-w-7xl mx-auto">
        <div class="reveal flex items-end justify-between gap-6 flex-wrap mb-11">
          <h2 class="font-display font-black text-[clamp(34px,4.6vw,60px)] leading-[0.96] tracking-[-0.015em] text-blue-black">
            ¿Qué necesitas <em class="italic text-orange">crear?</em>
          </h2>
          <p class="text-[15.5px] leading-[1.55] text-blue-black/70 max-w-[330px]">
            Del primer boceto al render final, bajo un mismo techo. No subcontratamos la parte difícil.
          </p>
        </div>
        <div class="reveal grid grid-cols-2 lg:grid-cols-4 gap-[18px]">
          {needs.map(([no, name, desc], i) => {
            const dark = i % 2 === 1;
            return (
              <div
                data-cursor="link"
                class:list={[
                  'pop-card pop-border pop-shadow-sm rounded-[20px] p-[22px_20px] min-h-[186px] flex flex-col cursor-pointer',
                  dark ? 'bg-skill-blue text-cream' : 'bg-cream text-blue-black',
                ]}
              >
                <span
                  class:list={[
                    'pop-badge self-start text-xs px-2.5 py-1',
                    dark ? 'bg-orange text-blue-black' : 'bg-skill-blue text-cream',
                  ]}
                >
                  {no}
                </span>
                <p class="font-display font-semibold text-[21px] leading-[1.05] mt-4 mb-1.5">{name}</p>
                <p class="text-[12.5px] leading-[1.45] opacity-[0.82]">{desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ══ TEASER MÉTODO ══ -->
    <section id="method" class="bg-blue-black py-[70px] px-6 lg:px-[46px] border-y-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto grid md:grid-cols-[1.4fr_auto] gap-8 items-center">
        <div class="reveal">
          <h2 class="font-display font-black text-[clamp(30px,4vw,52px)] leading-[0.98] text-cream mb-3">
            Por qué funciona cuando otro contenido <em class="italic text-orange">no.</em>
          </h2>
          <p class="text-base leading-[1.58] text-cream/72 max-w-[560px]">
            Historia, oficio y algo de ciencia bajo el capó. Hay un método detrás de los
            personajes que la gente cita años después.
          </p>
        </div>
        <div class="reveal">
          <a
            href="/es/metodologia/"
            class="pop-btn pop-btn-accent-shadow pop-border inline-block bg-cream text-blue-black text-[15px] font-extrabold px-7 py-[15px] rounded-full"
          >
            Cómo trabajamos →
          </a>
        </div>
      </div>
    </section>

    <!-- ══ CONTACTO ══ -->
    <section id="contacto" class="bg-cream py-[90px] px-6 lg:px-[46px] border-t-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto grid lg:grid-cols-[0.9fr_1.1fr] gap-12 lg:gap-16 items-start">

        <!-- Izquierda: pitch -->
        <div class="reveal">
          <span class="pop-badge-sans pop-border text-xs bg-orange text-blue-black px-4 py-[7px] -rotate-2">Hablemos</span>
          <h2 class="font-display font-black text-[clamp(34px,4.6vw,60px)] leading-[0.94] tracking-[-0.02em] text-blue-black mt-6 mb-4">
            Cuéntanos qué estás <em class="italic text-orange">construyendo.</em>
          </h2>
          <p class="text-[15.5px] leading-[1.6] text-blue-black/72 mb-7 max-w-[440px]">
            Cuéntanos un poco sobre tu proyecto y cómo podemos ayudar. Los campos marcados con
            <span class="text-orange font-bold">*</span> son obligatorios.
          </p>
          <ul class="flex flex-col gap-3.5 mb-8">
            {[
              'Personajes, series, juegos y formación, bajo un mismo techo',
              'Respuesta en un día hábil',
              'Primera consulta gratuita',
            ].map((line) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-[2px] inline-flex items-center justify-center w-[22px] h-[22px] rounded-full bg-orange border-2 border-blue-black text-blue-black text-[12px] font-black">✓</span>
                <span class="text-[14.5px] leading-[1.5] text-blue-black/80">{line}</span>
              </li>
            ))}
          </ul>
          <p class="text-[14.5px] text-blue-black/70">
            ¿Prefieres correo? Escríbenos a <a href="mailto:miguel@emerito.co" class="font-bold text-orange underline underline-offset-2 hover:text-blue-black transition-colors">miguel@emerito.co</a>.
          </p>
        </div>

        <!-- Derecha: tarjeta del formulario -->
        <div class="reveal">
          <div id="home-form-card" class="bg-cream pop-border pop-shadow-lg rounded-[24px] p-6 sm:p-8">
            <form id="home-contact-form" method="POST" action="https://formspree.io/f/xwvdgjey" novalidate>
              <!-- honeypot: los bots lo llenan, los humanos nunca lo ven (Formspree filtra _gotcha) -->
              <div class="absolute w-px h-px -left-[9999px] overflow-hidden" aria-hidden="true">
                <label for="home-website">No completar</es/label>
                <input type="text" id="home-website" name="_gotcha" tabindex="-1" autocomplete="off" />
              </div>
              <input type="hidden" name="_subject" value="Nuevo contacto desde emerito.co (Inicio)" />
              <input type="hidden" name="tipo" value="Consulta desde la página de inicio" />
              <input type="hidden" name="lang" value="es" />

              <div class="grid sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <label for="home-nombre" class="block font-sans font-extrabold uppercase tracking-[0.06em] text-[12.5px] text-blue-black mb-1.5">Nombre <span class="text-orange">*</span></es/label>
                  <input type="text" id="home-nombre" name="nombre" required autocomplete="name"
                    class="w-full bg-white border-[2.5px] border-blue-black rounded-[12px] px-3.5 py-2.5 text-[15px] text-blue-black outline-none focus:border-orange" />
                </div>
                <div>
                  <label for="home-email" class="block font-sans font-extrabold uppercase tracking-[0.06em] text-[12.5px] text-blue-black mb-1.5">Email <span class="text-orange">*</span></es/label>
                  <input type="email" id="home-email" name="email" required autocomplete="email"
                    class="w-full bg-white border-[2.5px] border-blue-black rounded-[12px] px-3.5 py-2.5 text-[15px] text-blue-black outline-none focus:border-orange" />
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-4 mb-1">
                <div>
                  <label for="home-empresa" class="block font-sans font-extrabold uppercase tracking-[0.06em] text-[12.5px] text-blue-black mb-1.5">Empresa</es/label>
                  <input type="text" id="home-empresa" name="empresa" autocomplete="organization"
                    class="w-full bg-white border-[2.5px] border-blue-black rounded-[12px] px-3.5 py-2.5 text-[15px] text-blue-black outline-none focus:border-orange" />
                </div>
                <div>
                  <label for="home-phone" class="block font-sans font-extrabold uppercase tracking-[0.06em] text-[12.5px] text-blue-black mb-1.5">Teléfono</es/label>
                  <input type="tel" id="home-phone" name="phone" autocomplete="tel"
                    class="w-full bg-white border-[2.5px] border-blue-black rounded-[12px] px-3.5 py-2.5 text-[15px] text-blue-black outline-none focus:border-orange" />
                </div>
              </div>
              <p class="text-[12px] text-blue-black/50 mb-4">Opcional. Incluye indicativo de país / área si aplica.</p>

              <div class="mb-1">
                <label for="home-mensaje" class="block font-sans font-extrabold uppercase tracking-[0.06em] text-[12.5px] text-blue-black mb-1.5">Mensaje <span class="text-orange">*</span></es/label>
                <textarea id="home-mensaje" name="mensaje" required rows="4" maxlength="5000"
                  class="w-full bg-white border-[2.5px] border-blue-black rounded-[12px] px-3.5 py-2.5 text-[15px] text-blue-black outline-none focus:border-orange resize-y"></textarea>
              </div>
              <p class="text-[12px] text-blue-black/50 mb-5">Máximo 5000 caracteres.</p>

              <p id="home-form-error" class="hidden text-sm text-red-600 mb-4" role="alert"></p>

              <button
                id="home-submit-btn"
                type="submit"
                class="pop-btn pop-border pop-shadow-sm inline-flex items-center gap-2 bg-orange text-blue-black text-[15px] font-extrabold px-7 py-3.5 rounded-full"
              >
                Enviar mensaje →
              </button>
            </form>
          </div>

          <!-- Estado de éxito (se muestra al enviar) -->
          <div id="home-form-success" class="hidden bg-cream pop-border pop-shadow-lg rounded-[24px] p-8 text-center">
            <span class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-orange border-[3px] border-blue-black text-blue-black text-2xl font-black mb-4">✓</span>
            <p class="font-display font-black text-[26px] text-blue-black mb-2">¡Listo, gracias!</p>
            <p class="text-[15px] text-blue-black/70">Te respondemos en un día hábil.</p>
          </div>
        </div>

      </div>
    </section>

  </div>

  <script>
    const root = document.querySelector('.pop-root');
    if (root) {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Parallax sutil al scroll para elementos con data-parallax (ej. el badge "¡hola!" del hero).
      if (!reduceMotion) {
        const pxEls = Array.from(root.querySelectorAll<HTMLElement>('[data-parallax]')).map((el) => ({
          el,
          speed: parseFloat(el.getAttribute('data-parallax') || '0') || 0,
        }));

        const applyParallax = () => {
          pxEls.forEach(({ el, speed }) => {
            const r = el.getBoundingClientRect();
            const center = r.top + r.height / 2 - window.innerHeight / 2;
            el.style.translate = `0 ${center * speed}px`;
          });
        };

        window.addEventListener('scroll', applyParallax, { passive: true });
        window.addEventListener('resize', applyParallax);
        applyParallax();
      }
    }

    // ── Formulario de contacto: envía a la API compartida y cambia la tarjeta por un gracias al enviar. ──
    const homeForm = document.getElementById('home-contact-form') as HTMLFormElement | null;
    const homeCard = document.getElementById('home-form-card');
    const homeSuccess = document.getElementById('home-form-success');
    const homeError = document.getElementById('home-form-error');
    const homeSubmit = document.getElementById('home-submit-btn') as HTMLButtonElement | null;

    homeForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!homeForm || !homeSubmit) return;

      homeError?.classList.add('hidden');
      homeSubmit.disabled = true;
      homeSubmit.textContent = 'Enviando…';

      try {
        const res = await fetch('https://formspree.io/f/xwvdgjey', {
          method: 'POST',
          body: new FormData(homeForm),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          homeCard?.classList.add('hidden');
          homeSuccess?.classList.remove('hidden');
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'generate_lead', form_name: 'home_page', language: 'es' });
        } else {
          const data = (await res.json().catch(() => ({}))) as { errors?: { message: string }[] };
          if (homeError) {
            homeError.textContent = data.errors?.map((x) => x.message).join(', ') || 'Algo salió mal. Intentá de nuevo.';
            homeError.classList.remove('hidden');
          }
          homeSubmit.disabled = false;
          homeSubmit.textContent = 'Enviar mensaje →';
        }
      } catch {
        if (homeError) {
          homeError.textContent = 'Error de conexión. Intentá de nuevo.';
          homeError.classList.remove('hidden');
        }
        homeSubmit.disabled = false;
        homeSubmit.textContent = 'Enviar mensaje →';
      }
    });
  </script>
</BaseLayout>
