---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'es' && !data.draft);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.pubDate.toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  lang="es"
  alternateHref="/insights"
>
  <div class="pop-root relative w-full overflow-hidden">

    <!-- ══ HEADER ══ -->
    <section class="bg-cream pt-20 pb-14 px-6 lg:px-[46px] border-b-[3px] border-blue-black">
      <div class="max-w-4xl mx-auto">
        <a href="/es/insights/" class="pop-nav-link inline-block font-mono text-[12px] font-bold tracking-[0.08em] uppercase text-blue-black/55 mb-7">← Todos los insights</a>
        <p class="pop-badge text-xs px-3.5 py-1.5 bg-orange text-blue-black border-[2.5px] border-blue-black mb-6">{post.data.category}</p>
        <h1 class="font-display font-medium text-[clamp(34px,4.6vw,64px)] leading-[0.95] tracking-[-0.02em] text-blue-black mb-5">
          {post.data.title}
        </h1>
        <p class="text-lg leading-[1.6] text-blue-black/70 mb-4">{post.data.description}</p>
        <p class="font-mono text-[12px] font-bold tracking-[0.08em] uppercase text-blue-black/45">{dateStr}</p>
      </div>
    </section>

    <!-- ══ PORTADA ══ -->
    {post.data.cover && (
      <div class="bg-cream px-6 lg:px-[46px] pt-12">
        <figure class="max-w-4xl mx-auto pop-border pop-shadow-md rounded-[20px] overflow-hidden m-0">
          <img src={post.data.cover} alt={post.data.title} class="w-full block" loading="eager" />
        </figure>
      </div>
    )}

    <!-- ══ ARTÍCULO ══ -->
    <article class="bg-cream py-[70px] px-6 lg:px-[46px]">
      <div class="prose-pop max-w-3xl mx-auto">
        <Content />
      </div>
    </article>

    <!-- ══ CTA ══ -->
    <section class="bg-orange py-[70px] px-6 lg:px-[46px] text-center border-t-[3px] border-blue-black">
      <div class="max-w-[640px] mx-auto">
        <h2 class="font-display font-medium text-[clamp(28px,3.8vw,48px)] leading-[0.98] text-blue-black mb-6">
          ¿Estás creando algo <em class="italic">que la gente debería recordar?</em>
        </h2>
        <a
          href="/es/#contacto"
          class="pop-btn pop-border inline-block bg-blue-black text-cream text-[16px] font-extrabold px-8 py-4 rounded-full"
          style="box-shadow: 7px 7px 0 #FFF6E4;"
        >
          Hablemos →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

<style is:global>
  .prose-pop {
    color: color-mix(in srgb, var(--color-blue-black) 82%, transparent);
    font-size: 17px;
    line-height: 1.7;
  }
  .prose-pop h3 {
    font-family: var(--font-display);
    color: var(--color-blue-black);
    font-size: clamp(24px, 3vw, 32px);
    margin: 2.2em 0 0.6em;
  }
  .prose-pop h4, .prose-pop h5 {
    font-family: var(--font-display);
    color: var(--color-blue-black);
    font-size: clamp(19px, 2.4vw, 24px);
    margin: 1.8em 0 0.5em;
  }
  .prose-pop p {
    margin: 0 0 1.2em;
  }
  .prose-pop img {
    border: 3px solid var(--color-blue-black);
    border-radius: 20px;
    box-shadow: 6px 6px 0 var(--color-blue-black);
    margin: 1.6em 0;
    width: 100%;
  }
  .prose-pop ul, .prose-pop ol {
    margin: 0 0 1.2em;
    padding-left: 1.4em;
  }
  .prose-pop li {
    margin-bottom: 0.5em;
  }
  .prose-pop a {
    color: var(--color-blue-black);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--color-orange);
    text-decoration-thickness: 2px;
  }
  .prose-pop a:hover {
    color: var(--color-orange);
  }
  .prose-pop blockquote {
    border-left: 4px solid var(--color-orange);
    margin: 1.6em 0;
    padding: 0.4em 0 0.4em 1.2em;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-blue-black);
  }
  .prose-pop strong {
    color: var(--color-blue-black);
  }
</style>
