---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Zero Risk Zone',
    label: 'Training series',
    desc: 'Safety protocols people actually want to watch, with Luisa, Andrés, and the Air Fan crew.',
    href: '/en/work/zero-risk-zone/',
    media: { type: 'img', src: '/images/Proyecto 1-Trabajo_Seguro_En_Alturas-AI/EquipoCambiandose.webp', alt: 'Zero Risk Zone, the Air Fan crew' },
  },
  {
    title: 'Palmódromo Medellín',
    label: 'Games & experiences',
    desc: 'A narrative racing game born from Medellín’s underground car culture.',
    href: '/en/work/palmodromo-medellin/',
    media: { type: 'video', src: '/images/Palmodromo/DriftRender.mp4' },
  },
  {
    title: 'Bacano Go!',
    label: 'Collectibles · Team credit',
    desc: 'The Carnaval de Barranquilla as digital collectibles. A project our founder helped build.',
    href: '/en/work/bacano-go/',
    media: { type: 'video', src: '/images/Bacano Go/Carnaval_Icons_Web.mp4' },
  },
  {
    title: 'Home in Motion',
    label: 'Real estate content',
    desc: 'One space, many stories. 3D reveals and AI-personalized content for listings.',
    href: '/en/work/home-in-motion/',
    media: { type: 'video', src: '/images/HomeInMotion/Render1_Loop.mp4' },
  },
  {
    title: 'The Lab',
    label: 'Experiments',
    desc: 'Rapid experiments in 3D, simulation, AI, and creative code. One day or less, published as-is.',
    href: '/en/lab/',
    media: { type: 'video', src: '/images/LAB/CatWalk_V020001-0109.mp4' },
  },
] as const;
---

<BaseLayout
  title="Work"
  description="Emerito's portfolio: character-driven training series, games, activations, digital fashion, and architectural animation. Worlds people remember."
  lang="en"
  alternateHref="/trabajo"
>
  <div class="pop-root relative w-full overflow-hidden">

    <!-- ══ HEADER ══ -->
    <section class="bg-cream pt-20 pb-14 px-6 lg:px-[46px] border-b-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto">
        <p class="pop-badge text-xs px-3.5 py-1.5 bg-orange text-blue-black border-[2.5px] border-blue-black mb-6">Portfolio</p>
        <h1 class="font-display font-medium text-[clamp(44px,6vw,92px)] leading-[0.9] tracking-[-0.025em] text-blue-black mb-6">
          Characters, stories & worlds <em class="italic text-orange">people remember.</em>
        </h1>
        <p class="text-lg leading-[1.6] text-blue-black/70 max-w-[560px]">
          Training series, games, activations, digital fashion. Every project starts
          as a character or a story, and ends as a world.
        </p>
      </div>
    </section>

    <!-- ══ PROJECT GRID ══ -->
    <section class="bg-cream py-[80px] px-6 lg:px-[46px]">
      <div class="max-w-7xl mx-auto grid sm:grid-cols-2 gap-7">
        {projects.map((p, i) => (
          <a
            href={p.href}
            data-cursor="cta"
            class:list={['pop-card pop-tile pop-border pop-shadow-md block rounded-[22px] overflow-hidden bg-cream', i === 0 ? 'sm:col-span-2' : '']}
          >
            <div class:list={['overflow-hidden bg-ocean relative', i === 0 ? 'aspect-[16/7]' : 'aspect-[16/10]']}>
              {p.media.type === 'video' ? (
                <video src={p.media.src} autoplay muted loop playsinline class="w-full h-full object-cover"></video>
              ) : (
                <img src={p.media.src} alt={'alt' in p.media ? p.media.alt : ''} class="w-full h-full object-cover" loading={i === 0 ? 'eager' : 'lazy'} />
              )}
              <span class="pop-badge absolute top-3.5 left-3.5 text-[10px] px-2.5 py-1 bg-orange text-blue-black">{p.label}</span>
            </div>
            <div class="p-[18px_22px_20px]">
              <p class="font-display text-[26px] leading-[1.05] text-blue-black mb-1">{p.title}</p>
              <p class="text-[14px] leading-[1.5] text-blue-black/60">{p.desc} →</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ══ CTA ══ -->
    <section class="bg-ocean py-[90px] px-6 lg:px-[46px] text-center border-t-[3px] border-blue-black">
      <div class="max-w-[640px] mx-auto">
        <h2 class="font-display font-medium text-[clamp(34px,4.6vw,60px)] leading-[0.95] text-cream mb-5">
          Your project could be <em class="italic text-orange">next.</em>
        </h2>
        <a
          href="/en/#contacto"
          data-cursor="cta"
          class="pop-btn pop-border pop-shadow-md inline-block bg-orange text-blue-black text-[16px] font-extrabold px-8 py-4 rounded-full"
        >
          Let's talk →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
