---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) =>
  data.lang === 'en' && !data.draft
);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Insights"
  description="Notes on behavior change, business futures, and creative communication."
  lang="en"
  alternateHref="/insights"
>

  <section class="bg-sand py-24 lg:py-28">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <p class="text-[10px] font-semibold tracking-[0.15em] uppercase text-accent mb-6">Insights</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-ocean leading-[1.05] mb-6">Insights</h1>
      <p class="text-lg text-ink/60 leading-relaxed max-w-2xl">
        Notes on behavior change, business futures, and creative communication.
      </p>
    </div>
  </section>

  <section class="bg-white border-y border-ink/6 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      {posts.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map(post => (
            <article>
              <figure class="bg-ink/8 rounded-sm aspect-video flex items-center justify-center mb-4">
                <figcaption class="text-[9px] text-ink/25 font-mono px-2 text-center">[IMG: cover_{post.id}.jpg]</figcaption>
              </figure>
              <p class="text-[10px] font-bold tracking-widest uppercase text-accent mb-2">{post.data.category}</p>
              <h2 class="text-lg font-bold text-ocean leading-snug mb-2">
                <a href={`/en/insights/${post.id}`} class="hover:text-accent transition-colors">{post.data.title}</a>
              </h2>
              <p class="text-xs text-ink/40 mb-2">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <p class="text-sm text-ink/60 leading-relaxed">{post.data.description}</p>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-ink/40 text-sm mb-4">Articles coming soon.</p>
          <p class="text-[10px] text-ink/25 font-mono">[TODO: add posts → src/content/blog/*.md]</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
