---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Let's talk about your project. We respond within 48 hours."
  lang="en"
  alternateHref="/contacto"
>

  <section class="bg-sand py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24">

      <div class="lg:pt-2">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-ocean leading-[1.05] mb-6">
          Let's talk.
        </h1>
        <p class="text-lg text-ink/60 leading-relaxed mb-10">
          Tell us about your project. We respond within 48 hours.
        </p>
        <div class="space-y-4 text-sm text-ink/50">
          <p>
            Or write to us directly at{' '}
            <a href="mailto:michael@emerito.co" class="text-ocean hover:text-accent transition-colors font-medium">
              michael@emerito.co
            </a>
          </p>
          <p>Medellín, Colombia</p>
        </div>
      </div>

      <div>
        <div
          id="form-success"
          class="hidden bg-cream border border-ink/10 rounded-sm p-8 text-center"
          role="alert"
        >
          <p class="text-ocean font-semibold text-lg mb-2">Thank you.</p>
          <p class="text-ink/65 text-sm">We'll respond within 48 hours.</p>
        </div>

        <form id="contact-form" method="POST" action="/api/contact" class="space-y-6" novalidate>
          <div class="hidden" aria-hidden="true">
            <label for="website">Do not fill</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="nombre" class="block text-xs font-semibold text-ink/60 uppercase tracking-widest mb-2">
                Name <span class="text-ocean">*</span>
              </label>
              <input type="text" id="nombre" name="nombre" required autocomplete="name"
                class="w-full bg-white border border-ink/15 rounded-sm px-4 py-3 text-sm text-ink placeholder-ink/30 focus:outline-none focus:border-ocean transition-colors"
                placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="block text-xs font-semibold text-ink/60 uppercase tracking-widest mb-2">
                Email <span class="text-ocean">*</span>
              </label>
              <input type="email" id="email" name="email" required autocomplete="email"
                class="w-full bg-white border border-ink/15 rounded-sm px-4 py-3 text-sm text-ink placeholder-ink/30 focus:outline-none focus:border-ocean transition-colors"
                placeholder="you@company.com" />
            </div>
          </div>

          <div>
            <label for="empresa" class="block text-xs font-semibold text-ink/60 uppercase tracking-widest mb-2">
              Company <span class="text-ink/30 font-normal normal-case tracking-normal">(optional)</span>
            </label>
            <input type="text" id="empresa" name="empresa" autocomplete="organization"
              class="w-full bg-white border border-ink/15 rounded-sm px-4 py-3 text-sm text-ink placeholder-ink/30 focus:outline-none focus:border-ocean transition-colors"
              placeholder="Your company name" />
          </div>

          <div>
            <label for="tipo" class="block text-xs font-semibold text-ink/60 uppercase tracking-widest mb-2">
              Project type <span class="text-ocean">*</span>
            </label>
            <select id="tipo" name="tipo" required
              class="w-full bg-white border border-ink/15 rounded-sm px-4 py-3 text-sm text-ink focus:outline-none focus:border-ocean transition-colors appearance-none">
              <option value="" disabled selected>Select an option</option>
              <option value="insight">Diagnostic (Cauce Insight)</option>
              <option value="studio">Full production (Cauce Studio)</option>
              <option value="unsure">Not sure yet</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="mensaje" class="block text-xs font-semibold text-ink/60 uppercase tracking-widest mb-2">
              Tell us about your project <span class="text-ocean">*</span>
            </label>
            <textarea id="mensaje" name="mensaje" required rows="5"
              class="w-full bg-white border border-ink/15 rounded-sm px-4 py-3 text-sm text-ink placeholder-ink/30 focus:outline-none focus:border-ocean transition-colors resize-none"
              placeholder="What behavior do you want to change? In what context? What has your company tried so far?"></textarea>
          </div>

          <p id="form-error" class="hidden text-sm text-red-600" role="alert"></p>

          <button type="submit" id="submit-btn"
            class="w-full bg-ocean text-sand text-sm font-semibold px-6 py-4 rounded-sm hover:bg-ocean/85 transition-colors disabled:opacity-50">
            Send
          </button>

          <p class="text-xs text-ink/35 text-center">
            The first conversation is free and no-commitment.
          </p>
        </form>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successBox = document.getElementById('form-success');
  const errorBox = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    errorBox?.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await res.json() as { ok?: boolean; error?: string };

      if (data.ok) {
        form.classList.add('hidden');
        successBox?.classList.remove('hidden');
      } else {
        if (errorBox) {
          errorBox.textContent = data.error ?? 'Something went wrong. Please try again.';
          errorBox.classList.remove('hidden');
        }
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send';
      }
    } catch {
      if (errorBox) {
        errorBox.textContent = 'Connection error. Please try again.';
        errorBox.classList.remove('hidden');
      }
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send';
    }
  });
</script>
