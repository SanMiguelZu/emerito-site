---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="We make communication that changes behavior. Diagnostics and films for companies where safety, training, or cultural change cannot fail."
  lang="en"
  alternateHref="/"
>

  <!-- ─── 1. HERO ─────────────────────────────────────────────────── -->
  <section class="bg-sand py-24 lg:py-36">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <div>
        <p class="text-xs font-semibold tracking-[0.15em] uppercase text-accent mb-6">
          Behavior-change studio · Medellín
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold text-ocean leading-[1.05] mb-6">
          We make communication that changes behavior.
        </h1>
        <p class="text-lg text-ink/60 leading-relaxed mb-10 max-w-lg">
          We design diagnostics and films for companies where safety,
          training, or cultural change cannot fail.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/en/case-studies/working-safely-at-heights"
            class="bg-ocean text-sand text-sm font-semibold px-6 py-3 rounded-sm hover:bg-ocean/85 transition-colors"
          >
            See the case: Veteran, Not Reckless →
          </a>
          <a
            href="/en/contact"
            class="text-ocean text-sm font-semibold px-6 py-3 rounded-sm border border-ocean/25 hover:border-ocean/60 transition-colors"
          >
            Let's talk
          </a>
        </div>
      </div>

      <!-- PLACEHOLDER: hero_visual.jpg/mp4 — Cauce motion graphic or Imprudencio still -->
      <figure class="bg-ocean/5 rounded-sm aspect-[4/3] flex items-center justify-center" aria-hidden="true">
        <svg viewBox="0 0 480 320" class="w-full h-full p-16 opacity-50" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 160 Q120 80 240 160 Q360 240 480 160" stroke="#3C9DC8" stroke-width="2.5" fill="none"/>
          <path d="M0 200 Q120 120 240 200 Q360 280 480 200" stroke="#3C9DC8" stroke-width="1.5" fill="none" opacity="0.5"/>
          <path d="M0 240 Q120 160 240 240 Q360 320 480 240" stroke="#0A3D62" stroke-width="1" fill="none" opacity="0.3"/>
          <circle cx="240" cy="160" r="5" fill="#3C9DC8" opacity="0.9"/>
        </svg>
      </figure>

    </div>
  </section>

  <!-- ─── 2. THREE PILLARS ─────────────────────────────────────────── -->
  <section class="bg-white border-y border-ink/6 py-20 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="text-xs font-semibold tracking-[0.15em] uppercase text-ink/35 text-center mb-14">
        Three disciplines. One channel.
      </p>
      <div class="grid md:grid-cols-3 gap-10 lg:gap-0">

        <div class="lg:pr-12">
          <p class="text-[10px] font-bold tracking-widest uppercase text-accent mb-4">01</p>
          <h3 class="text-lg font-bold text-ocean mb-1">Future Thinking</h3>
          <p class="text-sm text-ink/45 italic mb-4">We read the terrain</p>
          <p class="text-sm text-ink/65 leading-relaxed mb-6">
            We understand where the organization is heading and what behaviors will matter
            in three years. The foresight strategy that guides everything we design.
          </p>
          <p class="text-xs text-ink/35">Gloria Sánchez</p>
        </div>

        <div class="lg:px-12 lg:border-x lg:border-ink/8">
          <p class="text-[10px] font-bold tracking-widest uppercase text-accent mb-4">02</p>
          <h3 class="text-lg font-bold text-ocean mb-1">Behavioral Science</h3>
          <p class="text-sm text-ink/45 italic mb-4">We map the current</p>
          <p class="text-sm text-ink/65 leading-relaxed mb-6">
            We diagnose the real problem using COM-B: what capabilities, opportunities,
            and motivations determine why people do — or don't do — what they should.
          </p>
          <p class="text-xs text-ink/35">Julieta [surname]</p>
        </div>

        <div class="lg:pl-12">
          <p class="text-[10px] font-bold tracking-widest uppercase text-accent mb-4">03</p>
          <h3 class="text-lg font-bold text-ocean mb-1">Creative Content</h3>
          <p class="text-sm text-ink/45 italic mb-4">We trace the channel</p>
          <p class="text-sm text-ink/65 leading-relaxed mb-6">
            We build the intervention: the character, the story, the film that people
            actually watch and that, by design, changes how they act.
          </p>
          <p class="text-xs text-ink/35">Miguel Zuluaga</p>
        </div>

      </div>
      <div class="mt-14 text-center">
        <a href="/en/methodology" class="text-sm font-semibold text-ocean hover:text-accent transition-colors">
          See the full methodology →
        </a>
      </div>
    </div>
  </section>

  <!-- ─── 3. FEATURED CASE ─────────────────────────────────────────── -->
  <section class="bg-ocean py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="text-[10px] font-semibold tracking-[0.15em] uppercase text-sand/35 mb-10">
        Case study
      </p>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- PLACEHOLDER: airfan_candles.jpg — candle row still from Imprudencio storyboard -->
        <figure class="bg-sand/8 rounded-sm aspect-[4/3] flex items-center justify-center order-2 lg:order-1">
          <figcaption class="text-[10px] text-sand/25 font-mono text-center px-6 leading-relaxed">
            [IMAGE: airfan_candles.jpg<br/>Candle row — storyboard still<br/>1200 × 900 px]
          </figcaption>
        </figure>

        <div class="order-1 lg:order-2">
          <p class="text-[10px] font-bold tracking-widest uppercase text-accent mb-4">
            Working safely at heights
          </p>
          <h2 class="text-3xl lg:text-4xl font-extrabold text-sand leading-tight mb-5">
            Veteran, Not Reckless
          </h2>
          <p class="text-sand/65 text-base leading-relaxed mb-6">
            How do we get veteran technicians to follow safety protocol when
            crew culture punishes compliance?
          </p>
          <p class="text-sand/40 text-xs mb-8">
            Client: Airfan · Industrial HVAC maintenance · 2025
          </p>
          <!-- TODO: Airfan results data — add outcome chip once available -->
          <a
            href="/en/case-studies/working-safely-at-heights"
            class="inline-block bg-sand text-ocean text-sm font-semibold px-6 py-3 rounded-sm hover:bg-cream transition-colors"
          >
            Read the full case →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── 4. SERVICE TIERS ──────────────────────────────────────────── -->
  <section class="bg-sand py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="text-[10px] font-semibold tracking-[0.15em] uppercase text-ink/35 text-center mb-3">
        How we work with you
      </p>
      <h2 class="text-3xl font-extrabold text-ocean text-center mb-14">
        Two ways to start
      </h2>
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">

        <div class="bg-white border border-ink/8 rounded-sm p-8 lg:p-10">
          <p class="text-[10px] font-bold tracking-widest uppercase text-accent mb-5">Cauce Insight</p>
          <h3 class="text-2xl font-extrabold text-ocean mb-1">Diagnostic</h3>
          <p class="text-sm text-ink/45 mb-7">4 – 6 weeks</p>
          <p class="text-sm text-ink/65 leading-relaxed mb-7">
            We identify the real behavioral problem before producing anything.
            You get a behavioral map and an intervention strategy.
          </p>
          <ul class="text-sm text-ink/60 space-y-2.5 mb-8">
            {[
              'Stakeholder interviews',
              'Field observation',
              'COM-B diagnostic',
              'Behavioral map',
              'Intervention strategy',
              'Findings presentation',
            ].map(item => (
              <li class="flex gap-3">
                <span class="text-accent leading-none mt-0.5 flex-shrink-0">·</span>
                {item}
              </li>
            ))}
          </ul>
          <p class="text-xs text-ink/35 mb-8 leading-relaxed">
            For companies that want to understand the behavioral problem
            before committing to production.
          </p>
          <a href="/en/contact" class="block text-center bg-ocean text-sand text-sm font-semibold px-6 py-3 rounded-sm hover:bg-ocean/85 transition-colors">
            Let's talk
          </a>
        </div>

        <div class="bg-ocean rounded-sm p-8 lg:p-10">
          <p class="text-[10px] font-bold tracking-widest uppercase text-accent mb-5">Cauce Studio</p>
          <h3 class="text-2xl font-extrabold text-sand mb-1">Diagnostic + Production</h3>
          <p class="text-sm text-sand/45 mb-7">12 – 20 weeks</p>
          <p class="text-sm text-sand/65 leading-relaxed mb-7">
            Everything in Insight plus full production of the intervention:
            the film, series, or campaign that goes into the field.
          </p>
          <ul class="text-sm text-sand/60 space-y-2.5 mb-8">
            {[
              'Everything in Cauce Insight',
              'Concept and narrative development',
              'Character and story design',
              'Full audiovisual production',
              'Validation with end users',
              'Final deliverables',
            ].map(item => (
              <li class="flex gap-3">
                <span class="text-accent leading-none mt-0.5 flex-shrink-0">·</span>
                {item}
              </li>
            ))}
          </ul>
          <p class="text-xs text-sand/35 mb-8 leading-relaxed">
            For companies ready to produce a behavior-change piece.
          </p>
          <a href="/en/contact" class="block text-center bg-sand text-ocean text-sm font-semibold px-6 py-3 rounded-sm hover:bg-cream transition-colors">
            Let's talk
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── 5. WHY THIS MATTERS ───────────────────────────────────────── -->
  <section class="bg-cream border-y border-ink/6 py-20 lg:py-28">
    <div class="max-w-2xl mx-auto px-6 lg:px-8 text-center">
      <p class="text-[10px] font-semibold tracking-[0.15em] uppercase text-ink/35 mb-12">
        Why this matters
      </p>
      <p class="text-6xl lg:text-7xl font-extrabold text-ocean leading-none mb-3">694</p>
      <p class="text-lg font-semibold text-ocean mb-2">
        workers died in Colombia in 2023
      </p>
      <p class="text-sm text-ink/50 mb-3">
        from work-related causes. Construction deaths rose 47.4% compared to 2022.
      </p>
      <p class="text-[10px] text-ink/30 italic mb-12">
        Source: Consejo Colombiano de Seguridad / Fasecolda, 2023
      </p>
      <p class="text-ink/65 leading-relaxed">
        Most workplace deaths don't happen because workers lack knowledge.
        They happen because safety protocols collide with culture, habit, and
        operational pressure. That's what we design to change.
      </p>
    </div>
  </section>

  <!-- ─── 6. SELECTED WORK STRIP ───────────────────────────────────── -->
  <section class="bg-sand py-20 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <p class="text-[10px] font-semibold tracking-[0.15em] uppercase text-ink/35 mb-12">
        We also make
      </p>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        {[
          { name: 'Palmódromo Medellín', desc: 'Narrative game', file: 'palmodromo' },
          { name: 'Home in Motion', desc: 'Spatial visualization', file: 'home_in_motion' },
          { name: 'Bacano Go!', desc: 'Web3 for creators', file: 'bacano_go' },
          { name: 'Merch / Journey of Objects', desc: 'Merch design', file: 'merch' },
        ].map(p => (
          <figure>
            <div class="bg-ink/8 aspect-square rounded-sm flex items-center justify-center mb-3">
              <span class="text-[9px] text-ink/25 font-mono text-center px-2">[IMG: {p.file}.jpg]</span>
            </div>
            <figcaption>
              <p class="text-sm font-semibold text-ink">{p.name}</p>
              <p class="text-xs text-ink/45 mt-0.5">{p.desc}</p>
            </figcaption>
          </figure>
        ))}
      </div>
      <div class="mt-10">
        <a href="/en/work" class="text-sm font-semibold text-ocean hover:text-accent transition-colors">
          See more work →
        </a>
      </div>
    </div>
  </section>

  <!-- ─── 7. TEAM TEASER ───────────────────────────────────────────── -->
  <section class="bg-white border-y border-ink/6 py-20 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <div class="grid grid-cols-3 gap-5">
        {[
          { name: 'Gloria Sánchez', role: 'Futures', file: 'gloria' },
          { name: 'Julieta [surname]', role: 'Behavior', file: 'julieta' },
          { name: 'Miguel Zuluaga', role: 'Creative', file: 'miguel' },
        ].map(p => (
          <figure>
            <div class="bg-ink/8 aspect-square rounded-sm flex items-center justify-center mb-2">
              <span class="text-[8px] text-ink/25 font-mono text-center px-1">{p.file}.jpg</span>
            </div>
            <figcaption>
              <p class="text-xs font-semibold text-ink leading-tight">{p.name}</p>
              <p class="text-[10px] text-ink/40 mt-0.5">{p.role}</p>
            </figcaption>
          </figure>
        ))}
      </div>

      <div>
        <p class="text-[10px] font-semibold tracking-[0.15em] uppercase text-ink/35 mb-5">
          We are a family company
        </p>
        <p class="text-ink/65 leading-relaxed mb-7">
          Strategy, science, and narrative under one roof. That's why we can commit
          to behavioral outcomes, not just creative deliverables.
        </p>
        <a href="/en/team" class="text-sm font-semibold text-ocean hover:text-accent transition-colors">
          Meet the team →
        </a>
      </div>

    </div>
  </section>

  <!-- ─── 8. CLOSING CTA ───────────────────────────────────────────── -->
  <section class="bg-ocean py-24 lg:py-36 text-center">
    <div class="max-w-xl mx-auto px-6 lg:px-8">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-sand leading-tight mb-5">
        Does your next project need to change behavior?
      </h2>
      <p class="text-sand/55 text-lg mb-10">
        Let's talk. The first conversation is free.
      </p>
      <a
        href="/en/contact"
        class="inline-block bg-sand text-ocean text-sm font-semibold px-8 py-4 rounded-sm hover:bg-cream transition-colors"
      >
        Schedule a conversation →
      </a>
    </div>
  </section>

</BaseLayout>
