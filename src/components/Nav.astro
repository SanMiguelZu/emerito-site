---
interface Props {
  lang: 'es' | 'en';
  currentPath: string;
  alternateHref?: string;
}

const { lang, currentPath, alternateHref } = Astro.props;

const isEs = lang === 'es';

const navLinks = isEs
  ? [
      { href: '/trabajo/', label: 'Trabajo' },
      { href: '/insights/', label: 'Insights' },
      { href: '/metodologia/', label: 'Metodología' },
      { href: '/equipo/', label: 'Equipo' },
    ]
  : [
      { href: '/en/work/', label: 'Work' },
      { href: '/en/insights/', label: 'Insights' },
      { href: '/en/methodology/', label: 'Methodology' },
      { href: '/en/team/', label: 'Team' },
    ];

const ctaLabel = isEs ? 'Hablemos' : "Let's talk";
const ctaHref = isEs ? '/#contacto' : '/en/#contacto';
const altLabel = isEs ? 'EN' : 'ES';
const altHref = alternateHref ?? (isEs ? '/en/' : '/');
const homeHref = isEs ? '/' : '/en/';

function isActive(href: string): boolean {
  if (href === currentPath) return true;
  // Sub-pages: /trabajo/ matches /trabajo/zero-risk-zone/
  if (href !== '/' && currentPath.startsWith(href)) return true;
  return false;
}
---

<!-- Fixed header -->
<header id="site-nav" class="sticky top-0 z-40 bg-cream">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-[66px]">

    <!-- Logo wordmark -->
    <a
      href={homeHref}
      class="flex-shrink-0 inline-flex items-center"
      aria-label={isEs ? 'Emerito, inicio' : 'Emerito, home'}
    >
      <img src="/images/Emerito Logo.png" alt="Emerito" class="h-[38px] w-auto" />
    </a>

    <!-- Desktop nav links -->
    <nav
      class="hidden lg:flex items-center gap-7 text-sm"
      aria-label="Navegación principal"
    >
      {navLinks.map(link => (
        <a
          href={link.href}
          class={[
            'pop-nav-link font-bold',
            isActive(link.href) ? 'text-orange' : 'text-blue-black',
          ].join(' ')}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
      <a
        href={ctaHref}
        class="pop-btn pop-border bg-ocean text-cream text-sm font-bold px-5 py-2.5 rounded-full pop-shadow-sm"
      >
        {ctaLabel} →
      </a>
      <a
        href={altHref}
        class="font-sans text-[11px] font-extrabold tracking-[0.12em] uppercase text-blue-black/50 hover:text-orange transition-colors"
        aria-label={isEs ? 'Switch to English' : 'Cambiar a Español'}
      >
        {altLabel}
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="nav-open"
      class="lg:hidden p-2 -mr-2 text-blue-black"
      aria-label={isEs ? 'Abrir menú' : 'Open menu'}
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="flex flex-col gap-[5px]">
        <span class="block w-6 h-[3px] bg-blue-black rounded-full"></span>
        <span class="block w-6 h-[3px] bg-blue-black rounded-full"></span>
        <span class="block w-4 h-[3px] bg-blue-black rounded-full"></span>
      </span>
    </button>

  </div>
</header>

<!-- Mobile full-screen overlay -->
<div
  id="mobile-nav"
  class="hidden fixed inset-0 z-50 bg-blue-black flex-col"
  aria-label={isEs ? 'Menú móvil' : 'Mobile menu'}
  aria-hidden="true"
>
  <!-- Mobile header row -->
  <div class="flex items-center justify-between px-6 h-[66px] flex-shrink-0 border-b-[3px] border-cream/15">
    <a href={homeHref} class="inline-flex items-center">
      <img src="/images/Emerito Logo.png" alt="Emerito" class="h-[34px] w-auto" />
    </a>
    <button
      id="nav-close"
      class="p-2 -mr-2 text-cream"
      aria-label={isEs ? 'Cerrar menú' : 'Close menu'}
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile links -->
  <nav class="flex-1 flex flex-col justify-center px-8 gap-5" aria-label="Menú">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="font-display text-3xl font-medium italic text-cream hover:text-orange transition-colors leading-tight"
        data-mobile-link
      >
        {link.label}
      </a>
    ))}
  </nav>

  <!-- Mobile bottom row: lang toggle + CTA -->
  <div class="px-8 pb-12 flex items-center justify-between flex-shrink-0">
    <a
      href={altHref}
      class="font-sans text-[11px] font-extrabold tracking-[0.12em] uppercase text-cream/50 hover:text-cream transition-colors"
    >
      {altLabel}
    </a>
    <a
      href={ctaHref}
      class="pop-btn pop-border bg-orange text-blue-black text-sm font-bold px-6 py-3 rounded-full pop-shadow-sm"
    >
      {ctaLabel} →
    </a>
  </div>
</div>

<script>
  const openBtn  = document.getElementById('nav-open');
  const closeBtn = document.getElementById('nav-close');
  const menu     = document.getElementById('mobile-nav');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.classList.add('flex');
    menu?.setAttribute('aria-hidden', 'false');
    openBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.classList.remove('flex');
    menu?.setAttribute('aria-hidden', 'true');
    openBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  document.querySelectorAll('[data-mobile-link]').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeMenu();
  });

  // Soft shadow under the nav, only once the page has scrolled a little.
  const nav = document.getElementById('site-nav');
  const onScroll = () => nav?.classList.toggle('nav-scrolled', window.scrollY > 8);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
