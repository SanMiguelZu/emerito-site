---
// Shared layout for portfolio project pages (Pop Studio design system).
// Media items: { type: 'img' | 'video', src, alt?, caption? }
import BaseLayout from '../layouts/BaseLayout.astro';

interface Media {
  type: 'img' | 'video';
  src: string;
  alt?: string;
  caption?: string;
  /** Portrait media (e.g. character turnarounds) renders 3:4 instead of 4:3. */
  portrait?: boolean;
  /** Cutout media with transparent background: rendered without card, border, or background square. */
  transparent?: boolean;
}

interface Section {
  text: string;
  media?: Media[];
  /** 'stacked' centers the text on top with the media row below; 'carousel' does the same with a horizontal scroll strip (default: text beside media). */
  layout?: 'side' | 'stacked' | 'carousel';
}

interface Props {
  title: string;
  /** Optional logo image rendered inside the H1 instead of the title text (alt keeps SEO value). */
  titleImage?: { src: string; alt: string };
  label: string;
  description: string;
  intro: string;
  hero: Media;
  youtubeId?: string;
  /** Vertical (9:16) video, e.g. a YouTube Short. Rendered beside videoTitle/videoText. */
  videoVertical?: boolean;
  videoTitle?: string;
  videoText?: string;
  sections: Section[];
  next: { title: string; href: string };
  caseStudy?: { title: string; href: string };
  /** Optional highlighted call-to-action band (e.g. waitlist / support) shown before the next-project footer. */
  banner?: { badge?: string; title: string; text?: string; buttonText: string; href: string };
  /** Insert the page's slot content after this many content sections (default: after all of them). */
  slotAfter?: number;
  alternateHref?: string;
  /** Language of the page; drives the layout's chrome strings and internal links. */
  lang?: 'es' | 'en';
}

const { title, titleImage, label, description, intro, hero, youtubeId, videoVertical = false, videoTitle, videoText, sections, next, caseStudy, banner, slotAfter, alternateHref = '/en/work', lang = 'en' } = Astro.props;

const isEs = lang === 'es';
const t = {
  allWork: isEs ? '← Todo el trabajo' : '← All work',
  allWorkHref: isEs ? '/trabajo' : '/en/work',
  watch: isEs ? 'Ver' : 'Watch',
  caseBadge: isEs ? 'Caso de estudio' : 'Case study',
  caseTitle: isEs
    ? '¿Quieres la historia completa, <em class="italic">con la metodología y los resultados?</em>'
    : 'Want the full story, <em class="italic">with the methodology and results?</em>',
  caseBtn: isEs ? 'Lee el caso de estudio' : 'Read the case study',
  nextLabel: isEs ? 'Siguiente proyecto' : 'Next project',
  makeCta: isEs ? 'Hagamos algo juntos →' : 'Make something with us →',
  contactHref: isEs ? '/#contacto' : '/en#contacto',
};
---

<BaseLayout title={title} description={description} lang={lang} alternateHref={alternateHref}>
  <div class="pop-root relative w-full overflow-hidden">

    <!-- ══ HERO ══ -->
    <section class="bg-cream pt-20 pb-14 px-6 lg:px-[46px] border-b-[3px] border-blue-black">
      <div class="max-w-7xl mx-auto">
        <a href={t.allWorkHref} class="pop-nav-link inline-block font-mono text-[12px] font-bold tracking-[0.08em] uppercase text-blue-black/55 mb-7">{t.allWork}</a>
        <p class="pop-badge text-xs px-3.5 py-1.5 bg-orange text-blue-black border-[2.5px] border-blue-black mb-6">{label}</p>
        {titleImage ? (
          <h1 class="m-0 mb-7">
            <img src={titleImage.src} alt={titleImage.alt} class="h-[clamp(90px,14vw,180px)] w-auto" />
          </h1>
        ) : (
          <h1 class="font-display font-medium text-[clamp(44px,6vw,92px)] leading-[0.9] tracking-[-0.025em] text-blue-black mb-7 max-w-[900px]">
            {title}
          </h1>
        )}
        <p class="text-lg leading-[1.6] text-blue-black/75 max-w-[640px] mb-12" set:html={intro} />
        <figure class="pop-card pop-tile pop-border pop-shadow-lg m-0 rounded-[24px] overflow-hidden bg-ocean">
          {hero.type === 'video' ? (
            <video src={hero.src} autoplay muted loop playsinline class="w-full aspect-[16/8] object-cover"></video>
          ) : (
            <img src={hero.src} alt={hero.alt ?? title} class="w-full aspect-[16/8] object-cover" />
          )}
        </figure>
      </div>
    </section>

    <!-- ══ VIDEO ══ -->
    {youtubeId && !videoVertical && (
      <section class="bg-ocean py-[80px] px-6 lg:px-[46px] border-b-[3px] border-blue-black">
        <div class="max-w-5xl mx-auto">
          <div class="pop-card pop-border pop-shadow-lg relative rounded-[24px] overflow-hidden aspect-video bg-blue-black">
            <iframe
              src={`https://www.youtube.com/embed/${youtubeId}?rel=0&modestbranding=1&playsinline=1`}
              title={`${title} video`}
              class="w-full h-full border-0 block"
              allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture;web-share"
              allowfullscreen
              loading="lazy"
            ></iframe>
            <span class="pop-badge absolute top-4 left-4 z-[2] pointer-events-none text-[10.5px] px-3 py-1.5 bg-orange text-blue-black -rotate-[4deg]">
              {t.watch}
            </span>
          </div>
        </div>
      </section>
    )}

    {youtubeId && videoVertical && (
      <section class="bg-ocean py-[80px] px-6 lg:px-[46px] border-b-[3px] border-blue-black">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-[minmax(280px,380px)_1fr] gap-12 lg:gap-16 items-center justify-center">
          <div class="pop-card pop-border pop-shadow-lg relative rounded-[24px] overflow-hidden aspect-[9/16] bg-blue-black mx-auto w-full max-w-[380px]">
            <iframe
              src={`https://www.youtube.com/embed/${youtubeId}?rel=0&modestbranding=1&playsinline=1`}
              title={`${title} video`}
              class="w-full h-full border-0 block"
              allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture;web-share"
              allowfullscreen
              loading="lazy"
            ></iframe>
            <span class="pop-badge absolute top-4 left-4 z-[2] pointer-events-none text-[10.5px] px-3 py-1.5 bg-orange text-blue-black -rotate-[4deg]">
              {t.watch}
            </span>
          </div>
          <div class="reveal max-w-[560px]">
            {videoTitle && (
              <h2 class="font-display font-medium text-[clamp(32px,4.2vw,56px)] leading-[0.96] text-cream mb-5" set:html={videoTitle} />
            )}
            {videoText && (
              <p class="text-[17px] leading-[1.65] text-cream/82" set:html={videoText} />
            )}
          </div>
        </div>
      </section>
    )}

    <!-- ══ CONTENT SECTIONS ══ -->
    {sections.map((s, i) => {
      const stacked = s.layout === 'stacked' || s.layout === 'carousel';
      return (
      <>
      {i === slotAfter && <slot />}
      <section class:list={['py-[80px] px-6 lg:px-[46px]', i % 2 === 0 ? 'bg-cream' : 'bg-cream border-t-[3px] border-blue-black/10']}>
        <div class="max-w-7xl mx-auto">
          <div class:list={[stacked ? '' : 'grid gap-10 items-center', !stacked && s.media?.length ? 'lg:grid-cols-[0.9fr_1.1fr]' : '']}>
            <div class:list={['reveal', stacked ? 'max-w-[680px] mx-auto text-center mb-12' : '', !stacked && i % 2 === 1 && s.media?.length ? 'lg:order-2' : '']}>
              <p class:list={['text-[17px] leading-[1.65] text-blue-black/80', stacked ? '' : 'max-w-[560px]']} set:html={s.text} />
            </div>
            {s.media?.length && s.layout === 'carousel' && (
              <div class="reveal flex gap-5 overflow-x-auto pb-4 snap-x">
                {s.media.map((m) => (
                  <figure class:list={['pop-card pop-tile pop-border pop-shadow-md m-0 rounded-[20px] overflow-hidden bg-ocean relative shrink-0 snap-center h-[300px] sm:h-[380px]', m.portrait ? 'aspect-[3/4]' : 'aspect-[4/3]']}>
                    {m.type === 'video' ? (
                      <video src={m.src} autoplay muted loop playsinline class="w-full h-full object-cover"></video>
                    ) : (
                      <img src={m.src} alt={m.alt ?? ''} class="w-full h-full object-cover" loading="lazy" />
                    )}
                    {m.caption && (
                      <span class="font-mono absolute bottom-3 left-3.5 text-[10px] font-bold tracking-[0.08em] uppercase text-cream/80 bg-blue-black/60 rounded-full px-2.5 py-1">{m.caption}</span>
                    )}
                  </figure>
                ))}
              </div>
            )}
            {s.media?.length && s.layout !== 'carousel' && (
              <div class:list={['reveal grid gap-5 items-end', s.media.length === 3 ? 'grid-cols-3 max-sm:grid-cols-1' : s.media.length > 1 ? 'sm:grid-cols-2' : '', !stacked && i % 2 === 1 ? 'lg:order-1' : '', stacked && s.media.length === 1 ? 'max-w-[720px] mx-auto' : '', stacked && s.media.length === 3 ? 'max-w-[1000px] mx-auto' : '']}>
                {s.media.map((m) => m.transparent ? (
                  <figure class="relative m-0">
                    {m.type === 'video' ? (
                      <video src={m.src} autoplay muted loop playsinline class="w-full h-auto" style="filter: drop-shadow(0 20px 20px rgba(6,34,47,.25));"></video>
                    ) : (
                      <img src={m.src} alt={m.alt ?? ''} class="w-full h-auto" style="filter: drop-shadow(0 20px 20px rgba(6,34,47,.25));" loading="lazy" />
                    )}
                    {m.caption && (
                      <span class="font-mono absolute bottom-1 left-1/2 -translate-x-1/2 text-[10px] font-bold tracking-[0.08em] uppercase text-cream/85 bg-blue-black/70 rounded-full px-2.5 py-1">{m.caption}</span>
                    )}
                  </figure>
                ) : (
                  <figure class="pop-card pop-tile pop-border pop-shadow-md m-0 rounded-[20px] overflow-hidden bg-ocean relative">
                    {m.type === 'video' ? (
                      <video src={m.src} autoplay muted loop playsinline class:list={['w-full object-cover', m.portrait ? 'aspect-[3/4]' : 'aspect-[4/3]']}></video>
                    ) : (
                      <img src={m.src} alt={m.alt ?? ''} class:list={['w-full object-cover', m.portrait ? 'aspect-[3/4]' : 'aspect-[4/3]']} loading="lazy" />
                    )}
                    {m.caption && (
                      <span class="font-mono absolute bottom-3 left-3.5 text-[10px] font-bold tracking-[0.08em] uppercase text-cream/80 bg-blue-black/60 rounded-full px-2.5 py-1">{m.caption}</span>
                    )}
                  </figure>
                ))}
              </div>
            )}
          </div>
        </div>
      </section>
      </>
      );
    })}
    {(slotAfter === undefined || slotAfter >= sections.length) && <slot />}

    <!-- ══ CASE STUDY LINK (optional) ══ -->
    {caseStudy && (
      <section class="bg-orange py-[80px] px-6 lg:px-[46px] border-y-[3px] border-blue-black text-center">
        <div class="max-w-[760px] mx-auto">
          <p class="pop-badge text-xs px-3.5 py-1.5 bg-blue-black text-cream mb-5">{t.caseBadge}</p>
          <h2 class="font-display font-medium text-[clamp(30px,4.2vw,54px)] leading-[0.98] text-blue-black mb-8" set:html={t.caseTitle} />
          <a
            href={caseStudy.href}
            data-cursor="cta"
            class="pop-btn pop-border inline-block bg-blue-black text-cream text-[17px] font-extrabold px-9 py-[18px] rounded-full"
            style="box-shadow: 7px 7px 0 #FFF6E4;"
          >
            {t.caseBtn}: {caseStudy.title} →
          </a>
        </div>
      </section>
    )}

    <!-- ══ BANNER CTA (optional) ══ -->
    {banner && (
      <section class="bg-orange py-[80px] px-6 lg:px-[46px] border-y-[3px] border-blue-black text-center">
        <div class="max-w-[760px] mx-auto">
          {banner.badge && <p class="pop-badge text-xs px-3.5 py-1.5 bg-blue-black text-cream mb-5">{banner.badge}</p>}
          <h2 class="font-display font-medium text-[clamp(30px,4.2vw,54px)] leading-[0.98] text-blue-black mb-5" set:html={banner.title} />
          {banner.text && <p class="text-[17px] leading-[1.6] text-blue-black/78 mb-8 max-w-[560px] mx-auto" set:html={banner.text} />}
          <a
            href={banner.href}
            data-cursor="cta"
            class="pop-btn pop-border inline-block bg-blue-black text-cream text-[17px] font-extrabold px-9 py-[18px] rounded-full"
            style="box-shadow: 7px 7px 0 #FFF6E4;"
          >
            {banner.buttonText}
          </a>
        </div>
      </section>
    )}

    <!-- ══ NEXT PROJECT ══ -->
    <section class="bg-blue-black py-[90px] px-6 lg:px-[46px] text-center border-t-[3px] border-blue-black">
      <div class="max-w-[700px] mx-auto">
        <p class="font-mono text-[12px] font-bold tracking-[0.09em] uppercase text-cream/55 mb-4">{t.nextLabel}</p>
        <a href={next.href} data-cursor="cta" class="pop-nav-link inline-block font-display font-medium text-[clamp(36px,5vw,64px)] leading-[0.95] text-cream mb-8">
          {next.title} →
        </a>
        <div>
          <a
            href={t.contactHref}
            data-cursor="cta"
            class="pop-btn pop-border pop-shadow-sm inline-block bg-orange text-blue-black text-[15px] font-extrabold px-7 py-[15px] rounded-full"
          >
            {t.makeCta}
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
