---
// CaseCard — built in Step 3
interface Props {
  title: string;
  eyebrow: string;
  question: string;
  client: string;
  year: number;
  href: string;
  imageSrc?: string;
}
const { title, eyebrow, question, client, year, href, imageSrc } = Astro.props;
---

<!-- TODO Step 3: full case card layout -->
<article>
